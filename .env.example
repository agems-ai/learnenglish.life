# LearnEnglish.Life - Environment Variables Template
# COPY THIS TO .env AND FILL IN YOUR ACTUAL VALUES
# NEVER commit .env to version control!

# ============================================
# APPLICATION
# ============================================
PUBLIC_SITE_URL=https://learnenglish.life
PUBLIC_SITE_NAME=LearnEnglish.Life

# ============================================
# ANALYTICS (Google Analytics 4)
# ============================================
PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# GOOGLE ADSENSE
# ============================================
# Get these from Google AdSense dashboard
PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# ============================================
# DATABASE (PostgreSQL - for future dynamic features)
# ============================================
# DATABASE_URL will be set when PostgreSQL is configured
# DATABASE_URL=postgresql://user:password@localhost:5432/learnenglish

# ============================================
# AFFILIATE TRACKING
# ============================================
# These are public tracking IDs for affiliate programs
# They are safe to expose in frontend code
PUBLIC_ITAKI_AFFILIATE_ID=
PUBLIC_PREPLY_AFFILIATE_ID=
PUBLIC_CAMBLY_AFFILIATE_ID=

# ============================================
# SOCIAL MEDIA (OAuth - for future social login)
# ============================================
# These are for server-side use only
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=

# ============================================
# EMAIL (for newsletter subscriptions)
# ============================================
# EMAIL_PROVIDER_API_KEY=
# EMAIL_FROM_ADDRESS=noreply@learnenglish.life

# ============================================
# CLOUDINARY (image CDN)
# ============================================
# Get from https://cloudinary.com/console
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=production
