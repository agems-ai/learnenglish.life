---
// HeroCTA.astro - Conversion-optimized hero section with prominent CTA
interface Props {
  platform?: string; // 'italki' | 'preply' | 'cambly'
  rating?: number;
  reviewCount?: number;
  price?: string;
  ctaText?: string;
  ctaLink?: string;
  title?: string;
  subtitle?: string;
}

const {
  platform = "italki",
  rating = 4.7,
  reviewCount = 12500,
  price = "From $10/hr",
  ctaText = "Find Your Tutor (Free)",
  ctaLink = "/go/italki",
  title = "Find Your Perfect English Tutor",
  subtitle = "Join millions of learners improving their English with personalized 1-on-1 lessons",
} = Astro.props;

// Tailwind doesn't support dynamic class names, must use static lookup tables
const platforms: Record<string, { name: string; badge: string; cardBg: string; cardBorder: string; badgeBg: string; badgeText: string; ctaBg: string; ctaHover: string }> = {
  italki: {
    name: "iTalki",
    badge: "10M+ learners",
    cardBg: "bg-neutral-900",
    cardBorder: "border-emerald-700",
    badgeBg: "bg-emerald-900/40 border-emerald-700",
    badgeText: "text-emerald-300",
    ctaBg: "bg-emerald-600",
    ctaHover: "hover:bg-emerald-500",
  },
  preply: {
    name: "Preply",
    badge: "50K+ tutors",
    cardBg: "bg-neutral-900",
    cardBorder: "border-indigo-700",
    badgeBg: "bg-indigo-900/40 border-indigo-700",
    badgeText: "text-indigo-300",
    ctaBg: "bg-indigo-600",
    ctaHover: "hover:bg-indigo-500",
  },
  cambly: {
    name: "Cambly",
    badge: "Native speakers",
    cardBg: "bg-neutral-900",
    cardBorder: "border-teal-700",
    badgeBg: "bg-teal-900/40 border-teal-700",
    badgeText: "text-teal-300",
    ctaBg: "bg-teal-600",
    ctaHover: "hover:bg-teal-500",
  },
};

const p = platforms[platform] || platforms.italki;
---

<section class={`${p.cardBg} border ${p.cardBorder} rounded-2xl p-6 md:p-8 mb-8`}>
  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
    <!-- Left: Info -->
    <div class="flex-1">
      <!-- Platform badge -->
      <span class={`inline-block ${p.badgeBg} border ${p.badgeText} text-xs font-semibold px-3 py-1 rounded-full mb-3`}>
        {p.badge}
      </span>

      <!-- Title -->
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-2">
        {title}
      </h1>

      <!-- Subtitle -->
      <p class="text-neutral-300 mb-4 max-w-xl">
        {subtitle}
      </p>

      <!-- Trust indicators -->
      <div class="flex flex-wrap items-center gap-4 text-sm">
        <div class="flex items-center gap-1.5">
          <span class="text-yellow-400">★</span>
          <span class="font-semibold text-white">{rating}/5</span>
          <span class="text-neutral-400">({reviewCount.toLocaleString()} reviews)</span>
        </div>
        <div class="flex items-center gap-1.5">
          <span class="text-emerald-400 font-semibold">{price}</span>
        </div>
      </div>
    </div>

    <!-- Right: CTA -->
    <div class="flex-shrink-0">
      <a
        href={ctaLink}
        class={`block ${p.ctaBg} ${p.ctaHover} text-white text-center px-8 py-4 rounded-xl font-bold text-lg shadow-lg transform hover:scale-105 active:scale-95 transition-all`}
      >
        {ctaText} →
      </a>
      <p class="text-center text-xs text-neutral-400 mt-2">
        Free community access available
      </p>
    </div>
  </div>
</section>
