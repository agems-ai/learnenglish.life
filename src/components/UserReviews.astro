---
interface Props {
  platform: string;
}
const { platform } = Astro.props;
---
<div class="my-12 p-8 bg-neutral-900 border border-neutral-800 rounded-2xl">
  <h2 class="text-2xl font-bold text-white mb-6">User Reviews for {platform}</h2>
  <div class="text-center py-8">
    <p class="text-neutral-400 mb-4">No user reviews yet. Be the first to share your experience!</p>
    <button class="btn-secondary">Write a Review</button>
  </div>
</div>
