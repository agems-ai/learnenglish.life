---
interface Props {
  plans: Array<{ name: string; price: string; features: string[] }>;
}
const { plans } = Astro.props;
---
<div class="bg-neutral-900 border border-neutral-800 rounded-xl overflow-hidden">
  <div class="p-4 border-b border-neutral-800 bg-neutral-800/50">
    <h3 class="font-bold text-white">Pricing Plans</h3>
  </div>
  <div class="divide-y divide-neutral-800">
    {plans.map(plan => (
      <div class="p-4">
        <div class="flex justify-between items-center mb-2">
          <span class="text-white font-medium">{plan.name}</span>
          <span class="text-brand-400 font-bold">{plan.price}</span>
        </div>
        <ul class="text-xs text-neutral-400 space-y-1">
          {plan.features.slice(0, 3).map(f => <li>• {f}</li>)}
        </ul>
      </div>
    ))}
  </div>
</div>
