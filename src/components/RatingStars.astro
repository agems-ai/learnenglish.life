---
interface Props {
  rating: number;
  maxRating?: number;
  showValue?: boolean;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const {
  rating,
  maxRating = 5,
  showValue = true,
  size = 'md',
  class: className = '',
} = Astro.props;

const sizeClasses = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

const fullStars = Math.floor(rating);
const hasHalfStar = rating % 1 >= 0.5;
const emptyStars = maxRating - fullStars - (hasHalfStar ? 1 : 0);

const percentage = (rating / maxRating) * 100;
---

<div class:list={['flex items-center gap-1', className]}>
  <div class="relative inline-flex">
    <!-- Background stars (empty) -->
    <div class="flex gap-0.5">
      {Array.from({ length: maxRating }).map((_, i) => (
        <svg
          class:list={[sizeClasses[size], 'text-neutral-700']}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
    
    <!-- Filled stars overlay -->
    <div
      class="absolute top-0 left-0 flex gap-0.5 overflow-hidden"
      style={`width: ${percentage}%`}
    >
      {Array.from({ length: maxRating }).map((_, i) => (
        <svg
          class:list={[sizeClasses[size], 'text-yellow-400']}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
  </div>

  {showValue && (
    <span class="text-sm font-medium text-neutral-300 ml-1">
      {rating.toFixed(1)}
    </span>
  )}
</div>
