---
// Google AdSense — Header / In-Article Ad Unit
// Publisher ID: ca-pub-7792548915836467
// Usage: <AdHeader slot="1234567890" />
// After AdSense approval: replace slot prop with real ad unit ID from AdSense dashboard

interface Props {
  slot?: string;
}

const { slot = "HEADER_AD_SLOT" } = Astro.props;
---

<div class="ad-container ad-header my-6 text-center">
  <ins class="adsbygoogle"
       style="display:block; width:100%; max-width:728px; margin:0 auto; min-height:90px;"
       data-ad-client="ca-pub-7792548915836467"
       data-ad-slot={slot}
       data-ad-format="auto"
       data-full-width-responsive="true">
  </ins>
  <p class="ad-label text-xs text-gray-400 mt-1">Advertisement</p>
</div>

<script>
  (adsbygoogle = window.adsbygoogle || []).push({});
</script>
