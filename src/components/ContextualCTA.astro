---
interface Props {
  text: string;
  href?: string;
}

const { text, href = "/go/see-guru/" } = Astro.props;
---

<div class="bg-gradient-to-br from-emerald-900/50 to-teal-900/50 rounded-2xl p-6 border border-emerald-600 my-8 shadow-lg shadow-emerald-900/20">
  <div class="flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex-1 text-center md:text-left">
      <p class="text-xl font-bold text-white mb-1">Recommended for you</p>
      <p class="text-neutral-200">{text}</p>
    </div>
    <a 
      href={href} 
      target="_blank" 
      rel="noopener sponsored nofollow" 
      class="inline-block px-8 py-4 bg-emerald-600 text-white font-bold rounded-xl hover:bg-emerald-500 transition-all active:scale-95 whitespace-nowrap shadow-md shadow-emerald-900/40 text-center"
    >
      Try See Guru Free →
    </a>
  </div>
  <p class="text-[10px] text-neutral-400 mt-4 text-center md:text-left italic">
    *Disclosure: LearnEnglish.Life earns a commission if you sign up through this link.
  </p>
</div>
