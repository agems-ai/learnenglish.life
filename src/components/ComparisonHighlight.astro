---
// ComparisonHighlight.astro - Enhanced comparison table with winner highlighting
interface ComparisonRow {
  feature: string;
  winner?: string; // 'a' | 'b' | 'c' | null
  a: string;
  b: string;
  c?: string;
}

interface Props {
  title?: string;
  platformA: { name: string; slug: string; link: string };
  platformB: { name: string; slug: string; link: string };
  platformC?: { name: string; slug: string; link: string };
  winner?: 'a' | 'b'; // Recommended platform
  rows: ComparisonRow[];
}

const { 
  title = "How They Compare",
  platformA,
  platformB,
  platformC,
  winner = 'a',
  rows = []
} = Astro.props;
---

<section class="mb-8">
  {title && (
    <h2 class="text-2xl font-bold text-gray-900 mb-4">{title}</h2>
  )}
  
  <div class="overflow-x-auto">
    <table class="w-full border-collapse bg-white rounded-xl overflow-hidden shadow-sm">
      <thead>
        <tr class="bg-neutral-800">
          <th class="text-left p-4 font-semibold text-gray-700">Feature</th>
          <th class={`text-center p-4 font-semibold ${winner === 'a' ? 'bg-emerald-900/30 text-emerald-700' : 'text-gray-700'}`}>
            {platformA.name}
            {winner === 'a' && <span class="ml-1 text-xs bg-emerald-600 text-white px-2 py-0.5 rounded">Best</span>}
          </th>
          <th class={`text-center p-4 font-semibold ${winner === 'b' ? 'bg-emerald-900/30 text-emerald-700' : 'text-gray-700'}`}>
            {platformB.name}
            {winner === 'b' && <span class="ml-1 text-xs bg-emerald-600 text-white px-2 py-0.5 rounded">Best</span>}
          </th>
          {platformC && (
            <th class="text-center p-4 font-semibold text-gray-700">
              {platformC.name}
            </th>
          )}
        </tr>
      </thead>
      <tbody class="divide-y">
        {rows.map((row, index) => (
          <tr class="hover:bg-neutral-800 transition-colors">
            <td class="p-4 font-medium text-gray-700">{row.feature}</td>
            <td class={`p-4 text-center ${winner === 'a' && row.winner === 'a' ? 'bg-emerald-900/30 font-semibold' : ''}`}>
              {row.winner === 'a' ? (
                <span class="flex items-center justify-center gap-1">
                  <span class="text-emerald-600">✓</span>
                  <span>{row.a}</span>
                </span>
              ) : (
                <span>{row.a}</span>
              )}
            </td>
            <td class={`p-4 text-center ${winner === 'b' && row.winner === 'b' ? 'bg-emerald-900/30 font-semibold' : ''}`}>
              {row.winner === 'b' ? (
                <span class="flex items-center justify-center gap-1">
                  <span class="text-emerald-600">✓</span>
                  <span>{row.b}</span>
                </span>
              ) : (
                <span>{row.b}</span>
              )}
            </td>
            {platformC && row.c && (
              <td class="p-4 text-center text-gray-600">{row.c}</td>
            )}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
  
  <!-- CTA for winner -->
  <div class="mt-4 bg-emerald-900/30 border border-emerald-700 rounded-xl p-4 text-center">
    <p class="text-emerald-800 mb-2">
      <strong>{winner === 'a' ? platformA.name : platformB.name}</strong> is our top pick for most learners
    </p>
    <a 
      href={winner === 'a' ? platformA.link : platformB.link}
      class="inline-block bg-emerald-600 hover:bg-emerald-700 text-white font-bold px-6 py-2 rounded-lg transition-colors"
    >
      Try {winner === 'a' ? platformA.name : platformB.name} Free →
    </a>
  </div>
</section>
