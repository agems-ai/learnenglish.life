---
// Google AdSense Ad Unit Component
// Replace 'data-ad-slot' with real ad slot IDs from AdSense dashboard

interface Props {
  slot?: string;  // e.g., "1234567890"
  format?: "auto" | "rectangle" | "horizontal" | "vertical";
  layout?: string;
}

const {
  slot = "placeholder",
  format = "auto",
  layout = "in-article"
} = Astro.props;
---

<!-- AdSense Ad Unit -->
<ins class="adsbygoogle"
     style="display:block"
     data-ad-client="ca-pub-XXXXXXXXXX"
     data-ad-slot={slot}
     data-ad-format={format}
     data-full-width-responsive="true">
</ins>

<script>
  // Load ad only after user consent for marketing cookies
  if (typeof window !== 'undefined' && window['marketing-enabled']) {
    (adsbygoogle = window.adsbygoogle || []).push({});
  }
</script>
