---
/**
 * AdUnit — Centralized AdSense component for LearnEnglish.Life
 * 
 * Usage: <AdUnit slot="homepage_leaderboard" />
 * 
 * When AD_CONFIG.ENABLED is false or the slot has no ID,
 * renders a subtle placeholder div instead of a live ad.
 * The AdSense script is loaded once in Base.astro, not here.
 */
import { AD_CONFIG, hasSlotId, getSlotId } from "../config/ads";

interface Props {
  slot: string;                                    // Key from AD_CONFIG.SLOTS
  format?: "auto" | "rectangle" | "horizontal" | "vertical" | "fluid";
  className?: string;
  style?: string;
}

const {
  slot,
  format = "auto",
  className = "",
  style = "",
} = Astro.props;

const slotId = getSlotId(slot);
const isLive = hasSlotId(slot);

const bannerSrc = "/banners/seeguru-banner.jpg";
---

{isLive ? (
  <div class={`ad-container ${className}`} style={style}>
    <ins class="adsbygoogle"
         style="display:block"
         data-ad-client={AD_CONFIG.PUBLISHER_ID}
         data-ad-slot={slotId}
         data-ad-format={format}
         data-full-width-responsive="true">
    </ins>
  </div>
) : (
  <div class={`seeguru-ad bg-neutral-800/60 rounded-xl p-4 ${className}`} style={`margin:1rem 0;border:1px solid rgba(255,255,255,0.08);${style}`}>
    <p class="text-center text-xs text-slate-500 mb-2">Advertisement</p>
    <a href="/go/see-guru/" rel="sponsored nofollow" class="block">
      <picture>
        <source srcset="/banners/seeguru-banner.webp" type="image/webp" />
        <img
          src="/banners/seeguru-banner.jpg"
          alt="See Guru - Learn English 1-on-1 with certified teachers. Try 3 free lessons."
          loading="lazy"
          class="rounded-lg hover:opacity-90 transition-opacity w-full h-auto"
        />
      </picture>
    </a>
  </div>
)}
