---
// Google AdSense Ad Unit Component
// Publisher ID: ca-pub-7792548915836467

interface Props {
  slot?: string;  // e.g. "header", "in-article", "sidebar"
  format?: "auto" | "rectangle" | "horizontal" | "vertical" | "fluid";
}

const {
  slot = "placeholder",
  format = "auto"
} = Astro.props;
---

<!-- AdSense Ad Unit -->
<ins class="adsbygoogle"
     style="display:block; width:100%; min-height:90px;"
     data-ad-client="ca-pub-7792548915836467"
     data-ad-slot={slot}
     data-ad-format="auto"
     data-full-width-responsive="true">
</ins>

<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7792548915836467" crossorigin="anonymous"></script>
<script>
  (adsbygoogle = window.adsbygoogle || []).push({});
</script>
