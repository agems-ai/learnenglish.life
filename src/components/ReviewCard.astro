---
import RatingStars from './RatingStars.astro';

interface Props {
  slug: string;
  name: string;
  tagline?: string;
  rating: number;
  reviewCount?: number;
  price?: number;
  priceLabel?: string;
  badge?: string;
  category?: string;
  class?: string;
}

const {
  slug,
  name,
  tagline,
  rating,
  reviewCount,
  price,
  priceLabel = 'From',
  badge,
  category,
  class: className = '',
} = Astro.props;

const href = `/reviews/${slug}`;
const displayPrice = price !== undefined && price !== null && !isNaN(price) 
  ? new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 2 }).format(price)
  : null;
---

<article class:list={['group bg-white border border-neutral-200 rounded-xl overflow-hidden hover:border-emerald-500 hover:shadow-lg transition-all duration-200', className]}>
  <a href={href} class="block p-5">
    {badge && (
      <span class="inline-block px-2 py-0.5 text-xs font-medium bg-emerald-100 text-emerald-700 rounded-full mb-3">
        {badge}
      </span>
    )}

    <div class="flex items-start gap-4 mb-3">
      <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-lg flex items-center justify-center text-white font-bold text-lg shadow-sm">
        {name.charAt(0)}
      </div>
      
      <div class="flex-1 min-w-0">
        <h3 class="font-bold text-neutral-900 group-hover:text-emerald-600 transition-colors truncate !text-neutral-900">
          {name}
        </h3>
        {tagline && <p class="text-sm text-neutral-500 truncate">{tagline}</p>}
      </div>
    </div>

    <div class="flex items-center gap-3 mb-4">
      <RatingStars rating={rating} size="sm" />
      {reviewCount !== undefined && (
        <span class="text-sm text-neutral-500">({reviewCount.toLocaleString()} reviews)</span>
      )}
    </div>

    <div class="flex items-center justify-between pt-3 border-t border-neutral-100">
      {displayPrice ? (
        <div class="text-sm">
          <span class="text-neutral-500">{priceLabel}</span>
          <span class="font-semibold text-neutral-900 ml-1">{displayPrice}</span>
        </div>
      ) : (
        <div class="text-sm text-neutral-500">{priceLabel || 'See site'}</div>
      )}
      
      <span class="text-sm font-medium text-emerald-600 group-hover:underline">
        Read Review →
      </span>
    </div>
  </a>
</article>

<style>
  h3 {
    color: #111827 !important;
  }
</style>
