---
interface Props {
  reviews: Array<{ title: string; slug: string; rating: number; image?: string }>;
}
const { reviews } = Astro.props;
---
<div class="space-y-4">
  <h3 class="text-lg font-bold text-white">Related Reviews</h3>
  <div class="space-y-3">
    {reviews.map(rev => (
      <a href={`/reviews/${rev.slug}`} class="block p-3 bg-neutral-900 border border-neutral-800 rounded-lg hover:border-brand-500/50 transition-colors">
        <h4 class="text-sm font-medium text-white mb-1">{rev.title}</h4>
        <div class="text-xs text-yellow-500">★ {rev.rating}</div>
      </a>
    ))}
  </div>
</div>
