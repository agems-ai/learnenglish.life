---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Base 
  title="Privacy Policy | LearnEnglish.Life" 
  description="Learn how LearnEnglish.Life collects, uses, and protects your personal information. GDPR and CCPA compliant."
>
  <Header />
  
  <!-- Hero -->
  <section class="bg-emerald-600 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
        Privacy Policy
      </h1>
      <p class="text-emerald-100 text-lg">
        Effective Date: April 5, 2026 | Last Reviewed: April 6, 2026
      </p>
    </div>
  </section>

  <!-- Table of Contents -->
  <section class="py-8 bg-gray-950/60">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-lg font-semibold text-gray-100 mb-4">Table of Contents</h2>
      <nav class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
        <a href="#information-we-collect" class="text-emerald-600 hover:underline">1. Information We Collect</a>
        <a href="#how-we-use" class="text-emerald-600 hover:underline">2. How We Use Your Information</a>
        <a href="#legal-basis" class="text-emerald-600 hover:underline">3. Legal Basis for Processing (GDPR)</a>
        <a href="#third-party" class="text-emerald-600 hover:underline">4. Third-Party Services</a>
        <a href="#cookies" class="text-emerald-600 hover:underline">5. Cookies and Tracking</a>
        <a href="#data-retention" class="text-emerald-600 hover:underline">6. Data Retention</a>
        <a href="#data-security" class="text-emerald-600 hover:underline">7. Data Security</a>
        <a href="#your-rights" class="text-emerald-600 hover:underline">8. Your Rights</a>
        <a href="#gdpr-rights" class="text-emerald-600 hover:underline">9. GDPR-Specific Rights (EU)</a>
        <a href="#ccpa-rights" class="text-emerald-600 hover:underline">10. CCPA Rights (California)</a>
        <a href="#childrens-privacy" class="text-emerald-600 hover:underline">11. Children's Privacy</a>
        <a href="#international" class="text-emerald-600 hover:underline">12. International Data Transfers</a>
        <a href="#changes" class="text-emerald-600 hover:underline">13. Changes to This Policy</a>
        <a href="#contact" class="text-emerald-600 hover:underline">14. Contact Us</a>
      </nav>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none">
        
        <p class="text-gray-300 mb-6 text-lg">
          LearnEnglish.Life ("we," "our," or "us") is committed to protecting your privacy. This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website. Please read this privacy policy carefully.
        </p>

        <h2 id="information-we-collect" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">1</span>
          Information We Collect
        </h2>
        
        <h3 class="text-xl font-semibold text-gray-100 mt-6 mb-3">1.1 Information You Provide Directly</h3>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Email Address:</strong> When you subscribe to our newsletter, we collect your email address. This is the only personal data field we require.</li>
          <li><strong>User-Submitted Content:</strong> Reviews, comments, ratings, and feedback you submit become publicly visible content associated with your display name or "Anonymous."</li>
          <li><strong>Communication Data:</strong> If you contact us via email or our contact form, we may collect the content of your message and contact information.</li>
        </ul>

        <h3 class="text-xl font-semibold text-gray-100 mt-6 mb-3">1.2 Information Collected Automatically</h3>
        <p class="text-gray-300 mb-4">When you visit our website, we automatically collect certain technical information:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Device Information:</strong> Browser type, operating system, and device type.</li>
          <li><strong>Usage Data:</strong> Pages visited, time spent on pages, clicks, referring URLs, and navigation patterns.</li>
          <li><strong>Location Data:</strong> General geographic location inferred from IP address (city/region level only). We do not collect precise GPS location.</li>
          <li><strong>Cookie Data:</strong> Information stored in cookies as described in Section 5.</li>
        </ul>

        <h3 class="text-xl font-semibold text-gray-100 mt-6 mb-3">1.3 Data We Do NOT Collect</h3>
        <p class="text-gray-300 mb-4">We do not collect:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li>Full IP addresses (we store only truncated/obfuscated versions)</li>
          <li>Precise geolocation data</li>
          <li>Social security numbers or national ID numbers</li>
          <li>Financial or payment information (all payments are processed by third parties)</li>
          <li>Health or biometric data</li>
          <li>Passwords or authentication credentials</li>
        </ul>

        <h2 id="how-we-use" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">2</span>
          How We Use Your Information
        </h2>
        <p class="text-gray-300 mb-4">We use the information we collect for the following purposes:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Service Delivery:</strong> To provide, maintain, and improve our website and services.</li>
          <li><strong>Newsletter Delivery:</strong> To send newsletters and updates you have subscribed to (you can unsubscribe anytime).</li>
          <li><strong>Analytics:</strong> To understand how visitors use our site and identify areas for improvement.</li>
          <li><strong>Advertising:</strong> To display relevant advertisements through Google AdSense.</li>
          <li><strong>Security:</strong> To protect against fraud, abuse, and security threats.</li>
          <li><strong>Legal Compliance:</strong> To comply with applicable laws, regulations, and legal requests.</li>
          <li><strong>Communication:</strong> To respond to your inquiries and provide customer support.</li>
        </ul>

        <h2 id="legal-basis" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">3</span>
          Legal Basis for Processing (GDPR)
        </h2>
        <p class="text-gray-300 mb-4">If you are located in the European Economic Area (EEA), we process your personal data based on the following legal grounds under GDPR Article 6:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Consent (Art. 6(1)(a)):</strong> For newsletter subscriptions and non-essential cookies. You can withdraw consent at any time.</li>
          <li><strong>Legitimate Interests (Art. 6(1)(f)):</strong> For essential cookies, analytics, and security. We have conducted a balancing test to ensure our interests do not override your rights.</li>
          <li><strong>Contractual Necessity (Art. 6(1)(b)):</strong> For processing required to provide our service to you.</li>
          <li><strong>Legal Obligation (Art. 6(1)(c)):</strong> For compliance with applicable laws and regulations.</li>
        </ul>

        <h2 id="third-party" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">4</span>
          Third-Party Services
        </h2>
        <p class="text-gray-300 mb-4">We use the following third-party services, each with their own privacy policies:</p>

        <div class="bg-gray-950/60 rounded-xl p-6 mb-6">
          <h3 class="font-semibold text-gray-100 mb-3">Google Analytics 4</h3>
          <p class="text-sm text-gray-300 mb-2"><strong>Purpose:</strong> Website analytics and usage statistics</p>
          <p class="text-sm text-gray-300 mb-2"><strong>Data Collected:</strong> Pages visited, session duration, bounce rate, user demographics (aggregated), device/browser information</p>
          <p class="text-sm text-gray-300 mb-2"><strong>Privacy Policy:</strong> <a href="https://policies.google.com/privacy" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">policies.google.com/privacy</a></p>
          <p class="text-sm text-gray-300"><strong>Opt-out:</strong> <a href="https://tools.google.com/dlpage/gaoptout" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">Install Google Analytics Opt-out Browser Add-on</a></p>
        </div>

        <div class="bg-gray-950/60 rounded-xl p-6 mb-6">
          <h3 class="font-semibold text-gray-100 mb-3">Google AdSense</h3>
          <p class="text-sm text-gray-300 mb-2"><strong>Purpose:</strong> Displaying contextual and targeted advertisements</p>
          <p class="text-sm text-gray-300 mb-2"><strong>Data Collected:</strong> Ad impressions, clicks, viewing data, device identifiers, approximate location</p>
          <p class="text-sm text-gray-300 mb-2"><strong>Privacy Policy:</strong> <a href="https://policies.google.com/privacy" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">policies.google.com/privacy</a></p>
          <p class="text-sm text-gray-300"><strong>Opt-out:</strong> <a href="https://www.google.com/settings/ads" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">Google Ads Settings</a></p>
        </div>

        <div class="bg-gray-950/60 rounded-xl p-6 mb-6">
          <h3 class="font-semibold text-gray-100 mb-3">Cloudflare</h3>
          <p class="text-sm text-gray-300 mb-2"><strong>Purpose:</strong> Content delivery network (CDN), DDoS protection, and security</p>
          <p class="text-sm text-gray-300 mb-2"><strong>Data Collected:</strong> IP addresses (processed for security), request logs, threat detection data</p>
          <p class="text-sm text-gray-300"><strong>Privacy Policy:</strong> <a href="https://www.cloudflare.com/privacy-policy/" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">cloudflare.com/privacy-policy</a></p>
        </div>

        <div class="bg-gray-950/60 rounded-xl p-6 mb-6">
          <h3 class="font-semibold text-gray-100 mb-3">Cloudinary</h3>
          <p class="text-sm text-gray-300 mb-2"><strong>Purpose:</strong> Image hosting, optimization, and delivery</p>
          <p class="text-sm text-gray-300 mb-2"><strong>Data Collected:</strong> Uploaded images, image transformation requests</p>
          <p class="text-sm text-gray-300"><strong>Privacy Policy:</strong> <a href="https://cloudinary.com/privacy" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">cloudinary.com/privacy</a></p>
        </div>

        <div class="bg-gray-950/60 rounded-xl p-6 mb-6">
          <h3 class="font-semibold text-gray-100 mb-3">DigitalOcean</h3>
          <p class="text-sm text-gray-300 mb-2"><strong>Purpose:</strong> Website hosting and infrastructure</p>
          <p class="text-sm text-gray-300 mb-2"><strong>Data Collected:</strong> Server logs, hosting metadata</p>
          <p class="text-sm text-gray-300"><strong>Privacy Policy:</strong> <a href="https://www.digitalocean.com/legal/privacy-policy/" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">digitalocean.com/legal/privacy-policy</a></p>
        </div>

        <h2 id="cookies" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">5</span>
          Cookies and Tracking Technologies
        </h2>
        
        <h3 class="text-xl font-semibold text-gray-100 mt-6 mb-3">5.1 Types of Cookies We Use</h3>
        
        <div class="overflow-x-auto mb-6">
          <table class="min-w-full text-sm text-left text-gray-300">
            <thead class="bg-gray-950/60 text-xs uppercase text-gray-500">
              <tr>
                <th class="px-4 py-3">Cookie Type</th>
                <th class="px-4 py-3">Purpose</th>
                <th class="px-4 py-3">Duration</th>
                <th class="px-4 py-3">Required</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
              <tr>
                <td class="px-4 py-3 font-medium">Essential</td>
                <td class="px-4 py-3">Cookie consent preferences, site functionality</td>
                <td class="px-4 py-3">1 year</td>
                <td class="px-4 py-3 text-green-600 font-medium">Yes</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium">Analytics</td>
                <td class="px-4 py-3">Google Analytics 4 tracking</td>
                <td class="px-4 py-3">14 months</td>
                <td class="px-4 py-3 text-red-600 font-medium">No</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium">Advertising</td>
                <td class="px-4 py-3">Google AdSense personalization</td>
                <td class="px-4 py-3">3 months</td>
                <td class="px-4 py-3 text-red-600 font-medium">No</td>
              </tr>
              <tr>
                <td class="px-4 py-3 font-medium">Cloudflare</td>
                <td class="px-4 py-3">Security and CDN</td>
                <td class="px-4 py-3">Session</td>
                <td class="px-4 py-3 text-green-600 font-medium">Yes</td>
              </tr>
            </tbody>
          </table>
        </div>

        <h3 class="text-xl font-semibold text-gray-100 mt-6 mb-3">5.2 Managing Your Cookie Preferences</h3>
        <p class="text-gray-300 mb-4">When you first visit our site, you will see a cookie consent banner. You can:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Accept All:</strong> Enable all cookies including analytics and advertising.</li>
          <li><strong>Reject Non-Essential:</strong> Only essential cookies will be set.</li>
          <li><strong>Cookie Settings:</strong> Customize your preferences.</li>
        </ul>
        <p class="text-gray-300 mb-6">You can change your preferences at any time by clicking the "Cookie Settings" link in our footer.</p>

        <h2 id="data-retention" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">6</span>
          Data Retention
        </h2>
        <p class="text-gray-300 mb-4">We retain your personal data only for as long as necessary to fulfill the purposes outlined in this policy:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Email Subscriptions:</strong> Retained until you unsubscribe. After unsubscription, your email is deleted within 30 days.</li>
          <li><strong>Analytics Data:</strong> Retained for 26 months in Google Analytics (standard retention period).</li>
          <li><strong>Server Logs:</strong> Retained for 30 days for security purposes.</li>
          <li><strong>User-Submitted Content:</strong> Reviews and comments are retained indefinitely as they become part of our public content. You may request removal per Section 8.</li>
          <li><strong>Communication Records:</strong> Retained for 2 years after last contact.</li>
        </ul>

        <h2 id="data-security" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">7</span>
          Data Security
        </h2>
        <p class="text-gray-300 mb-4">We implement appropriate technical and organizational security measures to protect your personal data:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Encryption:</strong> All data transmitted to/from our site is encrypted via HTTPS (TLS 1.2+).</li>
          <li><strong>Secure Hosting:</strong> Our servers are hosted by DigitalOcean with industry-standard security.</li>
          <li><strong>Access Controls:</strong> Strict access controls limit who can access personal data.</li>
          <li><strong>Regular Updates:</strong> Software and systems are regularly updated to patch security vulnerabilities.</li>
          <li><strong>Security Monitoring:</strong> Cloudflare provides DDoS protection and threat detection.</li>
        </ul>
        <p class="text-gray-300 mb-6">While we strive to protect your information, no method of transmission over the Internet is 100% secure. We cannot guarantee absolute security.</p>

        <h2 id="your-rights" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">8</span>
          Your Rights. General
        </h2>
        <p class="text-gray-300 mb-4">Regardless of your location, you have the right to:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Access:</strong> Request a copy of the personal data we hold about you.</li>
          <li><strong>Correction:</strong> Request correction of inaccurate or incomplete data.</li>
          <li><strong>Deletion:</strong> Request deletion of your personal data (subject to legal retention requirements).</li>
          <li><strong>Opt-Out:</strong> Unsubscribe from marketing emails at any time (click "Unsubscribe" in any email).</li>
          <li><strong>Object:</strong> Object to certain processing of your data.</li>
          <li><strong>Data Portability:</strong> Receive your data in a structured, commonly used, machine-readable format.</li>
          <li><strong>Withdraw Consent:</strong> Withdraw consent where processing is based on consent.</li>
          <li><strong>Lodge Complaint:</strong> File a complaint with a data protection authority if you believe your rights have been violated.</li>
        </ul>

        <h2 id="gdpr-rights" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">9</span>
          GDPR-Specific Rights (European Users)
        </h2>
        <p class="text-gray-300 mb-4">If you are located in the European Economic Area (EEA), you have additional rights under the General Data Protection Regulation (GDPR):</p>
        
        <div class="bg-blue-950/60 border-l-4 border-blue-500 p-4 mb-6">
          <h3 class="font-semibold text-gray-100 mb-2">GDPR Articles 15-22. Your Rights</h3>
          <ul class="text-sm text-gray-300 space-y-1">
            <li><strong>Art. 15. Right of Access:</strong> Obtain confirmation of whether we process your data and access to that data.</li>
            <li><strong>Art. 16. Right to Rectification:</strong> Have inaccurate personal data corrected.</li>
            <li><strong>Art. 17. Right to Erasure:</strong> Request deletion of your personal data ("right to be forgotten").</li>
            <li><strong>Art. 18. Right to Restriction:</strong> Request restriction of processing in certain circumstances.</li>
            <li><strong>Art. 19. Notification:</strong> Receive notification of corrections, deletions, or restrictions.</li>
            <li><strong>Art. 20. Right to Portability:</strong> Receive your data in a structured, commonly used format.</li>
            <li><strong>Art. 21. Right to Object:</strong> Object to processing based on legitimate interests or public task.</li>
            <li><strong>Art. 22. Automated Decisions:</strong> Not be subject to solely automated decision-making with legal effects.</li>
          </ul>
        </div>

        <p class="text-gray-300 mb-4"><strong>Supervisory Authority:</strong> You have the right to lodge a complaint with your local data protection authority. For contact information, visit: <a href="https://edpb.europa.eu/about-edpb/about-edpb/members_en" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">edpb.europa.eu/members</a></p>

        <p class="text-gray-300 mb-4"><strong>Data Protection Officer:</strong> As a small-scale processor, we are not required to appoint a DPO. However, you can contact us at <a href="mailto:privacy@learnenglish.life" class="text-emerald-600 hover:underline">privacy@learnenglish.life</a> for all privacy matters.</p>

        <h2 id="ccpa-rights" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">10</span>
          CCPA Rights (California Residents)
        </h2>
        <p class="text-gray-300 mb-4">If you are a California resident, you have specific rights under the California Consumer Privacy Act (CCPA) and the California Privacy Rights Act (CPRA):</p>
        
        <div class="bg-purple-950/60 border-l-4 border-purple-500 p-4 mb-6">
          <h3 class="font-semibold text-gray-100 mb-2">Your California Rights</h3>
          <ul class="text-sm text-gray-300 space-y-2">
            <li><strong>Right to Know:</strong> Request disclosure of personal information collected, used, disclosed, or sold about you.</li>
            <li><strong>Right to Delete:</strong> Request deletion of personal information we have collected (subject to exceptions).</li>
            <li><strong>Right to Correct:</strong> Request correction of inaccurate personal information.</li>
            <li><strong>Right to Opt-Out:</strong> Opt out of the sale or sharing of personal information.</li>
            <li><strong>Right to Non-Discrimination:</strong> Not be discriminated against for exercising your privacy rights.</li>
            <li><strong>Right to Limit Use:</strong> Limit use of sensitive personal information to that which is necessary.</li>
          </ul>
        </div>

        <h3 class="text-lg font-semibold text-gray-100 mt-6 mb-3">Categories of Personal Information We Collect</h3>
        <p class="text-gray-300 mb-4">In the past 12 months, we have collected:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li><strong>Identifiers:</strong> Email address (only if you subscribe)</li>
          <li><strong>Internet Activity:</strong> Browsing history, interaction data, referring URLs</li>
          <li><strong>Geolocation Data:</strong> City/region level only (from IP address)</li>
          <li><strong>Inferences:</strong> Preferences and interests derived from browsing behavior</li>
        </ul>

        <h3 class="text-lg font-semibold text-gray-100 mt-6 mb-3">Do Not Sell or Share Personal Information</h3>
        <p class="text-gray-300 mb-4">We do <strong>NOT sell</strong> personal information in the traditional sense. However, we use advertising cookies that may be considered "sharing" under CCPA. You can opt out of this by:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li>Rejecting non-essential cookies when visiting our site</li>
          <li>Using the "Cookie Settings" link in our footer</li>
          <li>Installing the <a href="https://optout.aboutads.info/" class="text-emerald-600 hover:underline" target="_blank" rel="noopener">Digital Advertising Alliance Opt-Out</a></li>
        </ul>

        <h2 id="childrens-privacy" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">11</span>
          Children's Privacy
        </h2>
        <p class="text-gray-300 mb-6">
          Our website is not directed to children under 13 years of age (16 in the EEA under GDPR). We do not knowingly collect personal information from children under these ages. If you believe we have inadvertently collected such information, please contact us at <a href="mailto:privacy@learnenglish.life" class="text-emerald-600 hover:underline">privacy@learnenglish.life</a> and we will promptly delete the data.
        </p>

        <h2 id="international" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">12</span>
          International Data Transfers
        </h2>
        <p class="text-gray-300 mb-4">
          LearnEnglish.Life is operated from the United States. If you are located outside the U.S., your information will be transferred to and processed in the United States.
        </p>
        <p class="text-gray-300 mb-6">
          For transfers from the EEA to the U.S., we rely on Standard Contractual Clauses (SCCs) approved by the European Commission as appropriate safeguards under GDPR Article 46.
        </p>

        <h2 id="changes" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">13</span>
          Changes to This Privacy Policy
        </h2>
        <p class="text-gray-300 mb-4">We may update this Privacy Policy from time to time to reflect changes in our practices or legal requirements. When we make material changes:</p>
        <ul class="list-disc pl-6 text-gray-300 mb-6 space-y-2">
          <li>We will update the "Effective Date" at the top of this page</li>
          <li>We will post a notice on our homepage for 30 days</li>
          <li>For significant changes, we will obtain consent if required by law</li>
        </ul>
        <p class="text-gray-300 mb-6">We encourage you to review this Privacy Policy periodically.</p>

        <h2 id="contact" class="text-2xl font-bold text-gray-100 mt-8 mb-4 flex items-center">
          <span class="bg-emerald-900/40 text-emerald-300 rounded-full w-8 h-8 flex items-center justify-center text-sm font-bold mr-3">14</span>
          Contact Us
        </h2>
