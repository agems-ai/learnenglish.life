    <header class="mb-8">
      <span class="text-sm text-gray-400">Resource Guide · Updated April 2026</span>
      <h1 class="text-4xl font-bold mt-2 mb-4">Best YouTube Channels to Learn English (2026)</h1>
      <p class="text-lg text-gray-500 leading-relaxed">Discover the best YouTube channels to learn English in 2026. From grammar basics to advanced conversation, these 15 channels will accelerate your fluency.</p>
    </header>

    <!-- Quick Reference Table -->
    <div class="bg-green-50 border border-green-200 rounded-xl p-6 mb-8">
      <p class="font-bold text-lg mb-3">Quick Picks</p>
      <div class="overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full text-sm">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-4 py-2 text-left font-semibold text-gray-700">Skill</th>
              <th class="px-4 py-2 text-left font-semibold text-gray-700">Best Channel</th>
              <th class="px-4 py-2 text-left font-semibold text-gray-700">Level</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200">
            <tr>
              <td class="px-4 py-2 font-medium">Grammar</td>
              <td class="px-4 py-2"><a href="https://www.youtube.com/@engvid" target="_blank" rel="noopener" class="text-blue-600 hover:underline">EngVid</a></td>
              <td class="px-4 py-2">All levels</td>
            </tr>
            <tr>
              <td class="px-4 py-2 font-medium">Pronunciation</td>
              <td class="px-4 py-2"><a href="https://www.youtube.com/@EnglishwithLucy" target="_blank" rel="noopener" class="text-blue-600 hover:underline">English with Lucy</a></td>
              <td class="px-4 py-2">Intermediate+</td>
            </tr>
            <tr>
              <td class="px-4 py-2 font-medium">Vocabulary</td>
              <td class="px-4 py-2"><a href="https://www.youtube.com/@EnglishClass101" target="_blank" rel="noopener" class="text-blue-600 hover:underline">EnglishClass101</a></td>
              <td class="px-4 py-2">Beginner+</td>
            </tr>
            <tr>
              <td class="px-4 py-2 font-medium">Speaking</td>
              <td class="px-4 py-2"><a href="https://www.youtube.com/@PapaTeachMe" target="_blank" rel="noopener" class="text-blue-600 hover:underline">Papa Teach Me</a></td>
              <td class="px-4 py-2">Intermediate</td>
            </tr>
            <tr>
              <td class="px-4 py-2 font-medium">Listening</td>
              <td class="px-4 py-2"><a href="https://www.youtube.com/@bbclearningenglish" target="_blank" rel="noopener" class="text-blue-600 hover:underline">BBC Learning English</a></td>
