  "headline": title,
  "description": description,
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "publisher": {
    "@type": "Organization",
    "name": "LearnEnglish.Life",
    "logo": {
      "@type": "ImageObject",
      "url": "https://learnenglish.life/logo.png"
    }
  },
  "datePublished": "2026-04-10",
  "dateModified": "2026-04-10"
};

const listSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "British Council LearnEnglish"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "BBC Learning English"
    },
    {
      "@type": "ListItem",
      "position": 3,
