---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';

const resources = [
 {
 title: "Best YouTube Channels to Learn English",
 description: "Free lessons from native speakers covering grammar, pronunciation, vocabulary, and real conversation topics. Curated for every level.",
 icon: "Y",
 href: "/resources/best-youtube-channels-learn-english/",
 readTime: "8 min",
 level: "All Levels"
 },
 {
 title: "English Podcasts for Learners",
 description: "Audio lessons and conversations you can listen to anywhere. From beginner stories to advanced business English. Updated for 2026.",
 icon: "P",
 href: "/resources/english-podcasts-for-learners/",
 readTime: "7 min",
 level: "All Levels"
 },
 {
 title: "Free Online English Courses",
 description: "Accredited and community-driven courses that cost nothing. Find structured learning paths from top universities and language schools.",
 icon: "C",
 href: "/resources/free-online-english-courses/",
 readTime: "9 min",
 level: "Beginner to Advanced"
 }
];

const structuredData = {
 "@context": "https://schema.org",
 "@type": "CollectionPage",
 "name": "Free English Learning Resources",
 "description": "Curated free resources including YouTube channels, podcasts, and online courses for English learners.",
 "url": "https://learnenglish.life/resources/",
 "publisher": {
 "@type": "Organization",
 "name": "LearnEnglish.Life"
 }
};
---

<Base title="Free English Learning Resources" description="Curated free resources including YouTube channels, podcasts, and online courses for English learners at every level.">
 <Header />

 <main class="max-w-6xl mx-auto px-4 py-8">
 <div class="mb-8">
 <h1 class="text-4xl font-bold text-white mb-3">Free English Learning Resources</h1>
 <p class="text-neutral-400 text-lg max-w-2xl">Curated free resources to support your English learning journey. YouTube channels, podcasts, and free courses, all tested and reviewed.
 </p>
 </div>

 <AdUnit />

 <div class="grid gap-6 mt-8">
 {resources.map((resource) => (
 <a
 href={resource.href}
 class="group block bg-neutral-800 border border-neutral-700 rounded-xl p-6 hover:border-emerald-500/50 hover:bg-neutral-700/50 transition-all duration-200"
 >
 <div class="flex items-start gap-4">
 <span class="text-3xl flex-shrink-0">{resource.icon}</span>
 <div class="flex-1">
 <div class="flex items-center gap-3 mb-1">
 <h2 class="text-xl font-semibold text-white group-hover:text-emerald-400 transition-colors">
 {resource.title}
 </h2>
 <span class="text-xs px-2 py-0.5 rounded-full bg-emerald-900/50 text-emerald-400 border border-emerald-700">
 {resource.level}
 </span>
 </div>
 <p class="text-neutral-400 text-sm mb-2">{resource.description}</p>
 <span class="text-xs text-neutral-500">{resource.readTime} read</span>
 </div>
 <svg class="w-5 h-5 text-neutral-500 group-hover:text-emerald-400 group-hover:translate-x-1 transition-all flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
 </svg>
 </div>
 </a>
 ))}
 </div>

 <div class="mt-12 p-6 bg-neutral-800/50 border border-neutral-700 rounded-xl">
 <h3 class="text-lg font-semibold text-white mb-2">Looking for structured lessons?</h3>
 <p class="text-neutral-400 text-sm mb-4">Our guides section has in-depth articles covering grammar, vocabulary, IELTS prep, and more.</p>
 <a href="/guides/" class="inline-flex items-center gap-2 text-emerald-400 hover:text-emerald-300 text-sm font-medium">Browse all guides
 <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
 </svg>
 </a>
 </div>
 </main>

 <Footer />

 <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
</Base>
