---
import Base from "../../layouts/Base.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Are tutors under $15 per lesson actually good?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Many excellent tutors charge moderate rates. Community tutors on iTalki, for example, charge $4 to $10 per lesson and often provide high-quality conversational practice. Price alone is not a reliable quality indicator. Look at tutor reviews, response rates, and intro videos before booking."
      }
    },
    {
      "@type": "Question",
      "name": "Can I get a native English speaker for under $15?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sometimes. Platforms like iTalki and Preply have native English speakers at various price points. On iTalki, you may find community tutors who are native speakers at $8 to $12 per lesson. On Cambly, native-only tutors are available through subscription. See Guru has a limited selection of native speakers."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need to subscribe or buy a package?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not on See Guru, iTalki, or Verbling. Those platforms let you book and pay for individual lessons. Cambly and Lingoda require subscriptions. If you prefer pay-per-lesson flexibility, stick with the former three."
      }
    },
    {
      "@type": "Question",
      "name": "How do I find the best tutor for my goals under $15?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use filters. On iTalki, set your price range, select your target language, and filter by specialty (business, exam prep, conversation). Read at least three reviews per tutor before booking. Book a trial lesson first whenever possible."
      }
    },
    {
      "@type": "Question",
      "name": "What is the best platform for exam prep under $15?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iTalki is our top pick for exam prep under $15. Look for community tutors with positive reviews mentioning IELTS, TOEFL, or your target exam. Many have specific experience with these tests. See Guru also has tutors who specialize in exam preparation."
      }
    }
  ]
};
---

