 link: "/go/see-guru",
 bestFor: "Affordable tutors with flexible scheduling",
 pros: [
 "Certified human tutors starting at $5/hour",
 "1-on-1 video lessons via Zoom",
 "Pay-per-lesson model with no subscription required",
 "3 free trial lessons, no credit card needed",
 "Flexible scheduling across time zones"
 ],
