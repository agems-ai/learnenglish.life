 { feature: "Pricing Model", winner: null, a: "Pay per lesson", b: "Subscription" },
 { feature: "Teacher Certification", winner: null, a: "Certified diploma-holding", b: "Certified teachers" },
 { feature: "Curriculum", winner: "b", a: "Tutor-guided", b: "CEFR-aligned (A1-C2)" },
 { feature: "Class Format", winner: null, a: "One-on-one only", b: "Group + Private" },
 { feature: "Trial Available", winner: "a", a: "3 free lessons", b: "Limited" },
 { feature: "Scheduling", winner: null, a: "Book specific tutors", b: "24/7 classes" },
 { feature: "Certificate", winner: "b", a: "No", b: "Yes (course credits)" },
 { feature: "Pay-per-Lesson", winner: "a", a: "Yes", b: "No" },
 { feature: "Kids Section", winner: "a", a: "Yes", b: "Limited" }
];

// Benefits section
const whyCompare = [
 { icon: "$", title: "Different Learning Approaches", description: "See Guru offers flexible 1-on-1 Zoom lessons while Lingoda provides structured, curriculum-based education" },
 { icon: "vs", title: "Pricing Models", description: "Compare pay-per-lesson vs subscription costs to find what fits your budget" },
 { icon: "?", title: "Certification Goals", description: "Lingoda offers certificates; See Guru focuses on conversational practice" }
];

// Testimonials
const testimonials = [
 {
