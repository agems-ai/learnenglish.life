 <h2 class="text-2xl font-bold text-white">See Guru</h2>
 <div class="flex items-center">
 <span class="text-yellow-500 text-xl mr-1">★</span>
 <span class="text-2xl font-bold text-white">{seeGuru.rating}</span>
