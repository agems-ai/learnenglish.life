---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import SocialProof from '../../components/SocialProof.astro';
import BenefitCards from '../../components/BenefitCards.astro';
import ComparisonHighlight from '../../components/ComparisonHighlight.astro';

// Platform data
const seeGuru = {
  name: "See Guru",
  rating: 7.8,
  price: "$5-40/hr",
  link: "/go/see-guru",
  bestFor: "Affordable tutors with strong Asian selection",
  pros: [
    "Affordable lessons starting at $5/hour",
    "Strong Asian tutor selection (Chinese, Japanese, Korean)",
    "Pay-per-lesson model with no subscription required",
    "Trial lessons available for $1-5",
    "Good availability across time zones"
  ],
  cons: [
    "Smaller tutor pool than major platforms",
    "Basic vetting process",
    "Limited built-in curriculum",
    "Customer support can be slow"
  ]
};

const preply = {
  name: "Preply",
  rating: 8.4,
  price: "$10-40/hr",
  link: "/go/preply",
  bestFor: "Structured lessons with highly vetted tutors",
  pros: [
    "Rigorous tutor vetting process (only ~15% acceptance rate)",
    "Professional tutors with verified qualifications",
    "Trial lesson available before commitment",
    "Structured curriculum and learning plans",
    "Great for business English and exam prep"
  ],
  cons: [
    "Higher price point than See Guru",
    "Requires booking in advance",
    "Subscription model for some features",
    "Limited pay-per-lesson flexibility"
  ]
};

// Comparison rows
const comparison = [
  { feature: "Starting Price", winner: "a", a: "$5/hr", b: "$10/hr" },
  { feature: "Pricing Model", winner: null, a: "Pay per lesson", b: "Pay per lesson (with subscription option)" },
  { feature: "Tutor Pool Size", winner: "b", a: "Moderate", b: "Large (10,000+ tutors)" },
  { feature: "Vetting Process", winner: "b", a: "Basic", b: "Rigorous (~15% acceptance)" },
  { feature: "Asian Tutor Focus", winner: "a", a: "Excellent", b: "Good" },
  { feature: "Trial Available", winner: null, a: "Yes ($1-5)", b: "Yes (first lesson discounted)" },
  { feature: "Business English", winner: "b", a: "Basic", b: "Professional curriculum" },
  { feature: "Exam Prep Focus", winner: "b", a: "Limited", b: "IELTS, TOEFL, Cambridge certified tutors" },
  { feature: "Curriculum Built-in", winner: "b", a: "None", b: "Yes" },
  { feature: "Kid-Friendly", winner: null, a: "Limited", b: "Available" }
];

// Benefits section
const whyCompare = [
  { icon: "💰", title: "Different Price Points", description: "See Guru offers budget-friendly options while Preply provides premium vetted tutors. Find your sweet spot" },
  { icon: "🎓", title: "Quality vs Affordability", description: "Preply's rigorous vetting vs See Guru's accessible pricing. Choose based on your quality requirements" },
  { icon: "🌏", title: "Regional Specialties", description: "See Guru excels with Asian tutors; Preply provides global coverage with professional credentials" }
];

// Testimonials
const testimonials = [
  {
    quote: "See Guru connected me with an affordable Japanese tutor who understood my specific business needs. Perfect for my budget.",
    author: "Kenji T.",
    location: "Japan",
    result: "Business Japanese improved"
  },
  {
    quote: "Preply's vetted tutors helped me pass my IELTS exam. The structured approach made all the difference.",
    author: "Ana P.",
    location: "Brazil",
    result: "IELTS 8.0 achieved"
  },
  {
    quote: "I use See Guru for casual conversation practice and Preply when I need structured business lessons. Best of both worlds.",
    author: "Michael R.",
    location: "Germany",
    result: "Professional fluency gained"
  }
];

// SEO Schema
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "See Guru vs Preply: Which Online English Tutoring Platform Is Better in 2026?",
  "description": "Comprehensive comparison of See Guru and Preply online tutoring platforms. Compare pricing, tutor quality, features, and find the best platform for your English learning goals.",
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": "2026-04-07",
  "dateModified": "2026-04-07"
};

const comparisonSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Online Language Tutoring Platforms Comparison",
  "description": "Comparison between See Guru and Preply for English language learning"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is See Guru or Preply better for beginners?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both platforms work well for beginners, but with different strengths. See Guru offers more affordable entry points at $5/hour with flexible pay-per-lesson. Preply provides structured curriculum and vetted tutors but at higher price points ($10-40/hr). If budget is your priority, start with See Guru. If you want guaranteed quality and structured learning, Preply is better."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a lesson cost on See Guru vs Preply?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "See Guru starts at $5/hour with pay-per-lesson pricing. Preply ranges from $10-40/hour depending on tutor experience and qualifications. For budget-conscious learners, See Guru offers significant savings. For learners prioritizing tutor credentials and structured curriculum, Preply's higher prices often justify the investment."
      }
    },
    {
      "@type": "Question",
      "name": "Which platform has better tutor quality?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Preply has a more rigorous vetting process with only ~15% of tutor applications accepted. This means higher baseline quality but also higher prices. See Guru has a more basic vetting process but offers access to tutors with specific regional expertise, particularly in Asian languages and cultures, at lower price points."
      }
    },
    {
      "@type": "Question",
      "name": "Can I try either platform before committing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both platforms offer trial options. See Guru provides trial lessons typically priced between $1-5, allowing you to test multiple tutors at minimal cost. Preply offers a discounted or free first lesson with each tutor, helping you find the right match before regular lessons. Both allow testing before commitment."
      }
    }
  ]
};
---

<Base title="See Guru vs Preply: Which Online Tutoring Platform Is Better in 2026?" description="Compare See Guru and Preply online tutoring platforms. Find the best choice for your English learning goals, budget, and preferred teaching style.">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(comparisonSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  <Header />
  
  <main class="max-w-5xl mx-auto px-4 py-8 pb-24">
    <!-- Breadcrumb -->
    <nav class="text-sm text-neutral-300 mb-4">
      <a href="/" class="hover:text-emerald-600">Home</a>
      <span class="mx-2">›</span>
      <a href="/compare/" class="hover:text-emerald-600">Comparisons</a>
      <span class="mx-2">›</span>
      <span class="text-neutral-300">See Guru vs Preply</span>
    </nav>

    <!-- Hero Section -->
    <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-2xl p-8 text-white mb-8">
      <span class="text-emerald-200 text-sm font-medium">Comparison · Updated April 2026</span>
      <h1 class="text-4xl font-bold mt-2 mb-4">See Guru vs Preply: Which Online Tutoring Platform Is Better?</h1>
      <p class="text-emerald-100 text-lg">Budget-friendly flexibility meets professional rigor. We compare pricing, tutor quality, features, and user experience to help you choose the right platform.</p>
    </div>

    <!-- Quick Overview Cards -->
    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <!-- See Guru Card -->
      <div class="bg-white rounded-xl shadow-lg border-2 border-emerald-500 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-gray-100">See Guru</h2>
          <div class="flex items-center">
            <span class="text-yellow-500 text-xl mr-1">★</span>
            <span class="text-2xl font-bold text-gray-100">{seeGuru.rating}</span>
            <span class="text-gray-500 text-sm ml-1">/10</span>
          </div>
        </div>
        <div class="mb-4">
          <span class="text-3xl font-bold text-emerald-600">{seeGuru.price}</span>
        </div>
        <p class="text-neutral-400 mb-4"><strong>Best for:</strong> {seeGuru.bestFor}</p>
        <div class="mb-4">
          <h3 class="font-semibold text-green-300 mb-2">Pros</h3>
          <ul class="text-sm text-neutral-300 space-y-1">
            {seeGuru.pros.map(pro => <li class="flex items-start"><span class="text-green-500 mr-2">✓</span>{pro}</li>)}
          </ul>
        </div>
        <a href={seeGuru.link} class="block w-full bg-emerald-600 text-white text-center py-3 rounded-lg hover:bg-emerald-700 transition font-bold">
          Try See Guru Free →
        </a>
      </div>

      <!-- Preply Card -->
      <div class="bg-white rounded-xl shadow-lg border-2 border-purple-500 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-gray-100">Preply</h2>
          <div class="flex items-center">
            <span class="text-yellow-500 text-xl mr-1">★</span>
            <span class="text-2xl font-bold text-gray-100">{preply.rating}</span>
            <span class="text-gray-500 text-sm ml-1">/10</span>
          </div>
        </div>
        <div class="mb-4">
          <span class="text-3xl font-bold text-purple-600">{preply.price}</span>
        </div>
        <p class="text-neutral-400 mb-4"><strong>Best for:</strong> {preply.bestFor}</p>
        <div class="mb-4">
          <h3 class="font-semibold text-green-300 mb-2">Pros</h3>
          <ul class="text-sm text-neutral-300 space-y-1">
            {preply.pros.map(pro => <li class="flex items-start"><span class="text-green-500 mr-2">✓</span>{pro}</li>)}
          </ul>
        </div>
        <a href={preply.link} class="block w-full bg-purple-600 text-white text-center py-3 rounded-lg hover:bg-purple-700 transition font-bold">
          Try Preply Free →
        </a>
      </div>
    </div>

    <!-- Why Compare Section -->
    <BenefitCards 
      title="Why Compare These Platforms?"
      benefits={whyCompare}
    />

    <!-- Social Proof -->
    <SocialProof 
      title="What Learners Say"
      testimonials={testimonials}
    />

    <!-- Ad Unit -->
    <div class="mb-8">
      <AdUnit slot="compare-1" />
    </div>

    <!-- Enhanced Comparison Table -->
    <ComparisonHighlight 
      title="Feature Comparison"
      platformA={seeGuru}
      platformB={preply}
      winner="mixed"
      rows={comparison}
    />

    <!-- Ad Unit -->
    <div class="mb-8">
      <AdUnit slot="compare-2" />
    </div>

    <!-- Detailed Analysis -->
    <section class="bg-white rounded-xl shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-100 mb-6">Detailed Analysis</h2>
      
      <div class="mb-8">
        <h3 class="text-xl font-bold text-gray-100 mb-3">Pricing and Value</h3>
        <p class="text-neutral-300 leading-relaxed mb-4">
          <strong>See Guru</strong> operates on a pay-per-lesson model with prices starting at just $5/hour. This makes it accessible for occasional learners who want to control their spending. There's no subscription pressure, and you only pay for lessons you book.
        </p>
        <p class="text-neutral-300 leading-relaxed">
          <strong>Preply</strong> ranges from $10-40/hour depending on tutor qualifications and experience. While more expensive, Preply's rigorous vetting process (only ~15% acceptance rate) means you're paying for verified quality. The platform also offers structured curriculum and learning plans that justify the premium.
        </p>
      </div>

      <div class="mb-8">
        <h3 class="text-xl font-bold text-gray-100 mb-3">Tutor Quality and Selection</h3>
        <p class="text-neutral-300 leading-relaxed mb-4">
          <strong>See Guru</strong> has a moderate tutor pool with a focus on Asian tutors from China, Japan, and Korea. The vetting process is basic, which means quality varies. However, the platform excels at connecting learners with tutors from specific regions who understand cultural nuances.
        </p>
        <p class="text-neutral-300 leading-relaxed">
          <strong>Preply</strong> maintains strict quality standards with only 15% of tutor applications accepted. All tutors go through identity verification, background checks, and teaching ability assessments. Many Preply tutors hold teaching certifications like CELTA, TESOL, or have formal education backgrounds in language teaching.
        </p>
      </div>

      <div class="mb-8">
        <h3 class="text-xl font-bold text-gray-100 mb-3">Learning Experience</h3>
        <p class="text-neutral-300 leading-relaxed mb-4">
          <strong>See Guru</strong> offers more flexible interactions where you book specific tutors in advance at your preferred price point. The platform lacks built-in curriculum but allows for personalized sessions tailored to your exact needs. Trial lessons ($1-5) make it easy to test multiple tutors.
        </p>
        <p class="text-neutral-300 leading-relaxed">
          <strong>Preply</strong> provides a more structured learning experience with dedicated curriculum paths for business English, exam preparation (IELTS, TOEFL, Cambridge), and general conversation. Tutors create customized learning plans, and the platform tracks your progress over time.
        </p>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="bg-white rounded-xl shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-100 mb-6">Frequently Asked Questions</h2>
      
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">Is See Guru or Preply better for beginners?</h3>
          <p class="text-neutral-300">
            <strong>Both platforms work well</strong> for beginners, but with different strengths. See Guru offers more affordable entry points at $5/hour with flexible pay-per-lesson. Preply provides structured curriculum and vetted tutors but at higher price points ($10-40/hr). If budget is your priority, start with See Guru. If you want guaranteed quality and structured learning, Preply is better.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">How much does a lesson cost on See Guru vs Preply?</h3>
          <p class="text-neutral-300">
            <strong>See Guru starts at $5/hour</strong> with pay-per-lesson pricing. Preply ranges from <strong>$10-40/hour</strong> depending on tutor experience and qualifications. For budget-conscious learners, See Guru offers significant savings. For learners prioritizing tutor credentials and structured curriculum, Preply's higher prices often justify the investment.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">Which platform has better tutor quality?</h3>
          <p class="text-neutral-300">
            <strong>Preply has a more rigorous vetting process</strong> with only ~15% of tutor applications accepted. This means higher baseline quality but also higher prices. See Guru has a more basic vetting process but offers access to tutors with specific regional expertise, particularly in Asian languages and cultures, at lower price points.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">Can I try either platform before committing?</h3>
          <p class="text-neutral-300">
            <strong>Both platforms offer trial options.</strong> See Guru provides trial lessons typically priced between $1-5, allowing you to test multiple tutors at minimal cost. Preply offers a discounted or free first lesson with each tutor, helping you find the right match before regular lessons. Both allow testing before commitment.
          </p>
        </div>
      </div>
    </section>

    <!-- Ad Unit -->
    <div class="mb-8">
      <AdUnit slot="compare-3" />
    </div>

    <!-- Verdict Section -->
    <section class="bg-gradient-to-r from-emerald-900/40 to-teal-900/40 rounded-xl p-6 mb-8">
      <h2 class="text-2xl font-bold text-white mb-4">Our Verdict</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg p-4 border-l-4 border-emerald-500">
          <h3 class="font-bold text-gray-100 mb-2">Choose See Guru if:</h3>
          <ul class="text-neutral-300 space-y-2">
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>Budget is your primary concern</li>
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>Asian tutor selection is important to you</li>
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>You want maximum flexibility with pay-per-lesson</li>
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>You're a casual learner with occasional practice needs</li>
          </ul>
        </div>
        <div class="bg-white rounded-lg p-4 border-l-4 border-purple-500">
          <h3 class="font-bold text-purple-300 mb-2">Choose Preply if:</h3>
          <ul class="text-neutral-300 space-y-2">
            <li class="flex items-start"><span class="text-purple-500 mr-2">→</span>Tutor quality and credentials are essential</li>
            <li class="flex items-start"><span class="text-purple-500 mr-2">→</span>You need structured curriculum (business/exam prep)</li>
            <li class="flex items-start"><span class="text-purple-500 mr-2">→</span>You want a learning plan with progress tracking</li>
            <li class="flex items-start"><span class="text-purple-500 mr-2">→</span>You're serious about achieving specific language goals</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Related Reviews -->
    <section class="mb-8">
      <h2 class="text-xl font-bold text-white mb-4">Related Reviews</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/reviews/see-guru/" class="bg-white rounded-lg shadow p-4 hover:shadow-lg transition">
          <div class="flex items-center mb-2">
            <span class="text-yellow-500 mr-1">★</span>
            <span class="font-bold">7.8/10</span>
          </div>
          <h3 class="font-semibold text-gray-100">See Guru Review</h3>
          <p class="text-sm text-neutral-400">Full platform analysis</p>
        </a>
        <a href="/reviews/preply/" class="bg-white rounded-lg shadow p-4 hover:shadow-lg transition">
          <div class="flex items-center mb-2">
            <span class="text-yellow-500 mr-1">★</span>
            <span class="font-bold">8.4/10</span>
          </div>
          <h3 class="font-semibold text-gray-100">Preply Review</h3>
          <p class="text-sm text-neutral-400">Full platform analysis</p>
        </a>
      </div>
    </section>

    <!-- Affiliate Disclosure -->
    <div class="text-xs text-gray-500 mt-8 pt-4 border-t">
      <p><strong>Affiliate Disclosure:</strong> LearnEnglish.Life may earn commissions from qualifying purchases made through links on this page. This does not affect our reviews or ratings. We only recommend products we genuinely believe will help English learners.</p>
    </div>
  </main>

  <!-- Sticky CTA for Mobile -->
  <StickyCTA 
    ctaText="Compare Prices Now"
    ctaLink="/go/see-guru"
    platform="see-guru"
  />

  <Footer />
</Base>
