---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';

// Auto-discover every comparison page so we never have to maintain a hand-written list
const modules = import.meta.glob('./*.astro', { eager: true }) as Record<string, any>;

const seeGuruFirst = (slug: string) => slug.startsWith('see-guru') ? 0 : 1;

const comparisons = Object.entries(modules)
  .filter(([path]) => !path.endsWith('/index.astro'))
  .map(([path, mod]) => {
    const slug = path.replace('./', '').replace('.astro', '');
    const fallbackTitle = slug
      .replace(/-/g, ' ')
      .replace(/\bvs\b/gi, 'vs')
      .replace(/\b\w/g, (c) => c.toUpperCase());
    const title: string = mod?.frontmatter?.title || fallbackTitle;
    const description: string =
      mod?.frontmatter?.description ||
      `Side-by-side comparison: ${fallbackTitle}. Pricing, features and who each one is best for.`;
    const isVs = slug.includes('-vs-');
    const category = isVs ? 'Head to Head' : 'Roundup';
    return { title, description, href: `/compare/${slug}/`, category, slug };
  })
  .sort((a, b) => {
    const sg = seeGuruFirst(a.slug) - seeGuruFirst(b.slug);
    return sg !== 0 ? sg : a.title.localeCompare(b.title);
  });
---

<Base title="Compare English Learning Tools | LearnEnglish.Life" description="Compare the best English learning apps, tutoring platforms, and courses. Find the perfect fit for your budget, goals, and learning style.">
  <Header />
  
  <main class="max-w-6xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-white mb-4">Compare English Learning Tools</h1>
      <p class="text-xl text-neutral-400 max-w-3xl mx-auto">Find the perfect English learning solution for your needs. We compare apps, platforms, and courses side-by-side.</p>
    </div>

    <AdUnit slot="compare-index-1" />

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mt-8">
      {comparisons.map((item) => (
        <a href={item.href} class="block bg-slate-900/60 rounded-xl shadow-sm p-6 hover:shadow-lg transition-shadow">
          <span class="text-sm text-emerald-600 font-semibold">{item.category}</span>
          <h2 class="text-xl font-bold text-white mt-2 mb-3">{item.title}</h2>
          <p class="text-neutral-400 text-sm">{item.description}</p>
          <span class="inline-block mt-4 text-emerald-600 font-semibold">View Comparison →</span>
        </a>
      ))}
    </div>

    <AdUnit slot="compare-index-2" />

    <div class="mt-16 bg-blue-900/30 rounded-xl p-6">
      <h2 class="text-2xl font-bold text-white mb-4">Looking for Platform Reviews?</h2>
      <p class="text-neutral-400 mb-4">We also have in-depth reviews of individual platforms:</p>
      <div class="flex flex-wrap gap-3">
        <a href="/reviews/italki/" class="bg-slate-900/60 px-4 py-2 rounded-lg text-neutral-300 hover:bg-emerald-900/30 transition-colors">iTalki Review</a>
        <a href="/reviews/preply/" class="bg-slate-900/60 px-4 py-2 rounded-lg text-neutral-300 hover:bg-emerald-900/30 transition-colors">Preply Review</a>
        <a href="/reviews/cambly/" class="bg-slate-900/60 px-4 py-2 rounded-lg text-neutral-300 hover:bg-emerald-900/30 transition-colors">Cambly Review</a>
        <a href="/reviews/duolingo/" class="bg-slate-900/60 px-4 py-2 rounded-lg text-neutral-300 hover:bg-emerald-900/30 transition-colors">Duolingo Review</a>
        <a href="/reviews/babbel/" class="bg-slate-900/60 px-4 py-2 rounded-lg text-neutral-300 hover:bg-emerald-900/30 transition-colors">Babbel Review</a>
      </div>
    </div>
  </main>

  <Footer />
</Base>
