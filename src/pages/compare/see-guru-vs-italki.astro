---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import HeroCTA from '../../components/HeroCTA.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import BenefitCards from '../../components/BenefitCards.astro';
import SocialProof from '../../components/SocialProof.astro';
import ComparisonHighlight from '../../components/ComparisonHighlight.astro';
import PlatformRatings from '../../components/PlatformRatings.astro';
import { platformRatings } from '../../data/platform-ratings';

const seeGuru = {
  name: "See Guru",
  rating: 7.8,
  price: "$5-40/hr",
  link: "/go/see-guru",
  bestFor: "Affordable Asian tutors with flexible pricing",
  pros: [
    "Competitive pricing starting at $5/hour",
    "Strong selection of Asian tutors (Chinese, Japanese, Korean)",
    "Pay-per-lesson model with no subscription required",
    "Affordable trial lessons ($1-5)",
    "Good availability across time zones",
    "Video introductions on tutor profiles"
  ],
  cons: [
    "Smaller tutor pool than iTalki",
    "Basic vetting process",
    "Limited built-in curriculum",
    "Customer support can be slow"
  ]
};

const italki = {
  name: "iTalki",
  rating: 9.2,
  price: "$5-40/hr",
  link: "/go/italki",
  bestFor: "Speaking practice with the largest tutor network",
  pros: [
    "Massive tutor network (10,000+ teachers)",
    "Flexible scheduling with instant booking",
    "Affordable community tutor options from $5/hr",
    "User-friendly mobile app",
    "Lesson replay feature",
    "Established reputation with 10M+ learners"
  ],
  cons: [
    "Community tutors lack formal training",
    "Inconsistent quality among tutors",
    "No structured curriculum for complete beginners"
  ]
};

const comparison = [
  { feature: "Starting Price", winner: null, a: "$5/hr", b: "$5/hr" },
  { feature: "Average Lesson Cost", winner: null, a: "$10-20/hr", b: "$15-25/hr" },
  { feature: "Trial Lesson Cost", winner: "a", a: "$1-5", b: "$5-15" },
  { feature: "Tutor Pool Size", winner: "b", a: "Moderate", b: "10,000+" },
  { feature: "Native English Speakers", winner: "b", a: "Limited", b: "Yes" },
  { feature: "Asian Tutor Focus", winner: "a", a: "Excellent", b: "Good" },
  { feature: "Professional Certification", winner: "b", a: "Basic vetting", b: "Yes" },
  { feature: "Lesson Replay", winner: "b", a: "No", b: "Yes" },
  { feature: "Mobile App", winner: "b", a: "Basic", b: "iOS & Android" },
  { feature: "Subscription Required", winner: null, a: "No", b: "No" },
  { feature: "Scheduling Flexibility", winner: "b", a: "Good", b: "Excellent" }
];

const whyCompare = [
  { icon: "💰", title: "Similar Starting Prices", description: "Both platforms start at $5/hr, but See Guru often has lower average costs for Asian tutors" },
  { icon: "🌏", title: "Asian Tutor Excellence", description: "See Guru specializes in Asian tutors while iTalki offers a broader global selection" },
  { icon: "📊", title: "Scale vs Specialty", description: "iTalki offers volume and variety; See Guru offers focused expertise and competitive pricing" }
];

const testimonials = [
  {
    quote: "Moved from iTalki to See Guru for my Japanese tutor needs. Same quality, better prices!",
    author: "Michael T.",
    location: "USA",
    result: "Savings of $150/month"
  },
  {
    quote: "iTalki's massive network helped me find my perfect tutor. The lesson replay feature is invaluable.",
    author: "Sarah L.",
    location: "UK",
    result: "Fluent in 10 months"
  },
  {
    quote: "Both platforms serve different needs. See Guru for Asian tutors, iTalki for global variety.",
    author: "David K.",
    location: "Canada",
    result: "Progress across both platforms"
  }
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "See Guru vs iTalki: Which Online Tutoring Platform Is Better in 2026?",
  "description": "Comprehensive comparison of See Guru and iTalki online tutoring platforms. Compare pricing, tutor quality, features, and find the best platform for your English learning goals.",
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": "2026-04-07",
  "dateModified": "2026-04-07"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Is See Guru or iTalki better for finding Asian tutors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "See Guru is specifically strong for Asian tutors from China, Japan, and Korea, often at lower price points. iTalki has a broader global selection but See Guru excels in regional expertise and cultural understanding."
      }
    },
    {
      "@type": "Question",
      "name": "How much does a lesson cost on See Guru vs iTalki?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Both platforms start at $5/hour for community tutors. However, See Guru typically offers lower average prices ($10-20/hr) compared to iTalki ($15-25/hr). Trial lessons are also more affordable on See Guru ($1-5 vs $5-15 on iTalki)."
      }
    },
    {
      "@type": "Question",
      "name": "Which platform has better tutor quality?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "iTalki has more robust vetting and professional certification options, with lesson replay features. See Guru has basic vetting but excels in Asian tutor specialization. Quality ultimately depends on individual tutors rather than the platform."
      }
    },
    {
      "@type": "Question",
      "name": "Can I switch between See Guru and iTalki?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, both platforms work independently. Many learners use both: See Guru for Asian tutors and budget lessons, iTalki for broader tutor selection and professional instructors. No subscription is required on either platform."
      }
    }
  ]
};
---

<Base title="See Guru vs iTalki: Which Online Tutoring Platform Is Better in 2026?" description="Compare See Guru and iTalki online tutoring platforms. Find the best choice for your English learning goals, budget, and preferred tutor type.">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  
  <Header />
  
  <main class="max-w-5xl mx-auto px-4 py-8 pb-24">
    <!-- Breadcrumb -->
    <nav class="text-sm text-neutral-300 mb-4">
      <a href="/" class="hover:text-emerald-600">Home</a>
      <span class="mx-2">›</span>
      <a href="/compare/" class="hover:text-emerald-600">Comparisons</a>
      <span class="mx-2">›</span>
      <span class="text-neutral-300">See Guru vs iTalki</span>
    </nav>

    <!-- Hero Section -->
    <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-2xl p-8 text-white mb-8">
      <span class="text-emerald-200 text-sm font-medium">Comparison · Updated April 2026</span>
      <h1 class="text-4xl font-bold mt-2 mb-4">See Guru vs iTalki: Which Online Tutoring Platform Is Better?</h1>
      <p class="text-emerald-100 text-lg">Two affordable tutoring platforms compete for your attention. We compare pricing, tutor selection, and features to help you decide.</p>
    </div>

    <!-- Quick Overview Cards -->
    <div class="grid md:grid-cols-2 gap-6 mb-8">
      <!-- See Guru Card -->
      <div class="bg-slate-900/60 rounded-xl shadow-lg border-2 border-emerald-500 p-6">
        <div class="mb-3">
          <span class="inline-flex items-center gap-1 bg-yellow-500/20 border border-yellow-500/50 text-yellow-400 text-xs font-bold px-3 py-1 rounded-full">
            ⭐ Editor's Choice
          </span>
        </div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-gray-100">See Guru</h2>
          <div class="flex items-center">
            <span class="text-yellow-500 text-xl mr-1">★</span>
            <span class="text-2xl font-bold text-gray-100">7.8</span>
            <span class="text-slate-400 text-sm ml-1">/10</span>
          </div>
        </div>
        <div class="mb-4">
          <span class="text-3xl font-bold text-emerald-600">From $5/hr</span>
        </div>
        <p class="text-neutral-400 mb-4"><strong>Best for:</strong> Affordable Asian tutors with flexible pricing</p>
        <div class="mb-4">
          <h3 class="font-semibold text-green-300 mb-2">Pros</h3>
          <ul class="text-sm text-neutral-300 space-y-1">
            {seeGuru.pros.map(pro => <li class="flex items-start"><span class="text-green-500 mr-2">✓</span>{pro}</li>)}
          </ul>
        </div>
        <a href={seeGuru.link} class="block w-full bg-emerald-600 text-white text-center py-3 rounded-lg hover:bg-emerald-700 transition font-bold">
          Try See Guru Free →
        </a>
      </div>

      <!-- iTalki Card -->
      <div class="bg-slate-900/60 rounded-xl shadow-lg border-2 border-blue-500 p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-2xl font-bold text-gray-100">iTalki</h2>
          <div class="flex items-center">
            <span class="text-yellow-500 text-xl mr-1">★</span>
            <span class="text-2xl font-bold text-gray-100">9.2</span>
            <span class="text-slate-400 text-sm ml-1">/10</span>
          </div>
        </div>
        <div class="mb-4">
          <span class="text-3xl font-bold text-blue-600">From $5/hr</span>
        </div>
        <p class="text-neutral-400 mb-4"><strong>Best for:</strong> Speaking practice with the largest tutor network</p>
        <div class="mb-4">
          <h3 class="font-semibold text-green-300 mb-2">Pros</h3>
          <ul class="text-sm text-neutral-300 space-y-1">
            {italki.pros.map(pro => <li class="flex items-start"><span class="text-green-500 mr-2">✓</span>{pro}</li>)}
          </ul>
        </div>
        <a href={italki.link} class="block w-full bg-blue-600 text-white text-center py-3 rounded-lg hover:bg-blue-700 transition font-bold">
          Try iTalki Free →
        </a>
      </div>
    </div>

    <!-- Why Compare Section -->
    <BenefitCards 
      title="Why Compare These Platforms?"
      benefits={whyCompare}
    />

    <!-- Social Proof -->
    <SocialProof 
      title="What Learners Say"
      testimonials={testimonials}
    />

    <!-- Ad Unit -->
    <div class="mb-8">
      <AdUnit slot="compare-1" />
    </div>

    <!-- Enhanced Comparison Table -->
    <ComparisonHighlight 
      title="Feature Comparison"
      platformA={seeGuru}
      platformB={italki}
      winner="mixed"
      rows={comparison}
    />

    <!-- Ad Unit -->
    <div class="mb-8">
      <AdUnit slot="compare-2" />
    </div>

    <!-- Detailed Analysis -->
    <section class="bg-slate-900/60 rounded-xl shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-100 mb-6">Detailed Analysis</h2>
      
      <div class="mb-8">
        <h3 class="text-xl font-bold text-gray-100 mb-3">Pricing and Value</h3>
        <p class="text-neutral-300 leading-relaxed mb-4">
          <strong>Both platforms</strong> offer lessons starting at $5/hour, making them accessible for budget-conscious learners. However, See Guru often provides lower average prices ($10-20/hr) compared to iTalki ($15-25/hr). Trial lessons are notably cheaper on See Guru ($1-5) versus iTalki ($5-15).
        </p>
        <p class="text-neutral-300 leading-relaxed">
          <strong>iTalki's</strong> higher average price reflects its larger pool of certified professional teachers. See Guru offers better value for learners specifically seeking Asian tutors at competitive rates.
        </p>
      </div>

      <div class="mb-8">
        <h3 class="text-xl font-bold text-gray-100 mb-3">Tutor Selection and Quality</h3>
        <p class="text-neutral-300 leading-relaxed mb-4">
          <strong>iTalki</strong> dominates in scale with 10,000+ tutors including certified professional teachers, community tutors, and native English speakers. Their lesson replay feature and established reputation with 10M+ learners provide confidence in quality.
        </p>
        <p class="text-neutral-300 leading-relaxed">
          <strong>See Guru</strong> specializes in Asian tutors from China, Japan, and Korea. While the pool is smaller, the regional expertise and cultural understanding make it ideal for learners seeking native speakers from these regions at competitive prices.
        </p>
      </div>

      <div class="mb-8">
        <h3 class="text-xl font-bold text-gray-100 mb-3">User Experience</h3>
        <p class="text-neutral-300 leading-relaxed mb-4">
          <strong>iTalki</strong> offers superior mobile apps (iOS & Android), flexible instant booking, and lesson replay. Their established platform provides stability and extensive user reviews to inform decisions.
        </p>
        <p class="text-neutral-300 leading-relaxed">
          <strong>See Guru</strong> provides a cleaner, more focused interface for Asian tutor search. Video introductions on all tutor profiles help learners make informed decisions. Both platforms require no subscription.
        </p>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="bg-slate-900/60 rounded-xl shadow-lg p-6 mb-8">
      <h2 class="text-2xl font-bold text-gray-100 mb-6">Frequently Asked Questions</h2>
      
      <div class="space-y-6">
        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">Is See Guru or iTalki better for finding Asian tutors?</h3>
          <p class="text-neutral-300">
            <strong>See Guru is specifically strong</strong> for Asian tutors from China, Japan, and Korea, often at lower price points. iTalki has a broader global selection but See Guru excels in regional expertise and cultural understanding.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">How much does a lesson cost on See Guru vs iTalki?</h3>
          <p class="text-neutral-300">
            <strong>Both platforms start at $5/hour</strong> for community tutors. However, See Guru typically offers lower average prices ($10-20/hr) compared to iTalki ($15-25/hr). Trial lessons are also more affordable on See Guru ($1-5 vs $5-15 on iTalki).
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">Which platform has better tutor quality?</h3>
          <p class="text-neutral-300">
            <strong>iTalki has more robust vetting</strong> and professional certification options, with lesson replay features. See Guru has basic vetting but excels in Asian tutor specialization. Quality ultimately depends on individual tutors rather than the platform.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-semibold text-gray-100 mb-2">Can I switch between See Guru and iTalki?</h3>
          <p class="text-neutral-300">
            <strong>Yes, both platforms work independently.</strong> Many learners use both: See Guru for Asian tutors and budget lessons, iTalki for broader tutor selection and professional instructors. No subscription is required on either platform.
          </p>
        </div>
      </div>
    </section>

    <!-- Ad Unit -->
    <div class="mb-8">
      <AdUnit slot="compare-3" />
    </div>

    <!-- Verdict Section -->
    <section class="bg-gradient-to-r from-emerald-900/40 to-teal-900/40 rounded-xl p-6 mb-8">
      <h2 class="text-2xl font-bold text-white mb-4">Our Verdict</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-slate-900/60 rounded-lg p-4 border-l-4 border-emerald-500">
          <h3 class="font-bold text-gray-100 mb-2">Choose See Guru if:</h3>
          <ul class="text-neutral-300 space-y-2">
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>You specifically want Asian tutors (Chinese, Japanese, Korean)</li>
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>Budget is your primary concern</li>
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>You want affordable trial lessons ($1-5)</li>
            <li class="flex items-start"><span class="text-emerald-500 mr-2">→</span>Lower average costs matter to you</li>
          </ul>
        </div>
        <div class="bg-slate-900/60 rounded-lg p-4 border-l-4 border-blue-500">
          <h3 class="font-bold text-blue-300 mb-2">Choose iTalki if:</h3>
          <ul class="text-neutral-300 space-y-2">
            <li class="flex items-start"><span class="text-blue-500 mr-2">→</span>You want the largest tutor selection (10,000+)</li>
            <li class="flex items-start"><span class="text-blue-500 mr-2">→</span>Lesson replay is important to you</li>
            <li class="flex items-start"><span class="text-blue-500 mr-2">→</span>You want professional certified teachers</li>
            <li class="flex items-start"><span class="text-blue-500 mr-2">→</span>Global variety matters more than regional expertise</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Related Reviews -->
    <section class="mb-8">
      <h2 class="text-xl font-bold text-white mb-4">Related Reviews</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/reviews/see-guru/" class="bg-slate-900/60 rounded-lg shadow p-4 hover:shadow-lg transition">
          <div class="flex items-center mb-2">
            <span class="text-yellow-500 mr-1">★</span>
            <span class="font-bold">7.8/10</span>
          </div>
          <h3 class="font-semibold text-gray-100">See Guru Review</h3>
          <p class="text-sm text-neutral-400">Full platform analysis</p>
        </a>
        <a href="/reviews/italki/" class="bg-slate-900/60 rounded-lg shadow p-4 hover:shadow-lg transition">
          <div class="flex items-center mb-2">
            <span class="text-yellow-500 mr-1">★</span>
            <span class="font-bold">9.2/10</span>
          </div>
          <h3 class="font-semibold text-gray-100">iTalki Review</h3>
          <p class="text-sm text-neutral-400">Full platform analysis</p>
        </a>
      </div>
    </section>

    <!-- Affiliate Disclosure -->
    <div class="text-xs text-slate-400 mt-8 pt-4 border-t">
      <p><strong>Affiliate Disclosure:</strong> LearnEnglish.Life may earn commissions from qualifying purchases made through links on this page. This does not affect our reviews or ratings. We only recommend products we genuinely believe will help English learners.</p>
    </div>
  </main>

  <!-- Sticky CTA for Mobile -->
  <StickyCTA 
    ctaText="Compare Prices Now"
    ctaLink="/go/see-guru"
    platform="see-guru"
  />

  <Footer />
</Base>
