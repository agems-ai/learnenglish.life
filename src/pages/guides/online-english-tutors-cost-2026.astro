          <div>
            <p class="font-bold text-lg text-white">Ready to Find Your Tutor?</p>
            <p class="text-gray-400 text-sm mt-1">Compare prices and meet tutors from home.</p>
          </div>
          <a href="https://see.guru/?aff=SG-SUAG151" class="inline-block bg-green-600 text-white font-bold px-6 py-3 rounded-lg hover:bg-green-700 transition-colors whitespace-nowrap">
            Try See Guru Free
          </a>
        </div>
      </div>

      <AdUnit />

    </article>
  </main>

  <Footer />
</Base>
