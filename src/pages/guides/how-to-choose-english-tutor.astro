 <a href="/go/see-guru/" target="_blank" rel="noopener sponsored nofollow" class="inline-block px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors">Get 3 Free Lessons →</a>
 </div>
 </div>
 </div>
</aside>

 </main>

 <Footer />

</Base>
