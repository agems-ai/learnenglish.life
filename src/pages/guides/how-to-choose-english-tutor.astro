---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';

const factors = [
  { icon: "💰", title: "Budget", desc: "Community tutors $4-10/hr, professional tutors $15-50/hr" },
  { icon: "🎯", title: "Goals", desc: "Conversational, business, exam prep, pronunciation" },
  { icon: "⏰", title: "Availability", desc: "Match your time zone and schedule flexibility" },
  { icon: "🗣️", title: "Specialization", desc: "Native speakers, certified teachers, accent coaches" }
];

const questions = [
  "What is your current English level?",
  "What specific skills do you want to improve?",
  "How many hours per week can you dedicate?",
  "Do you prefer structured lessons or casual conversation?",
  "Are you preparing for a specific test or certification?"
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "How to Choose an English Tutor: The Complete Guide",
  "description": "Learn how to find the perfect English tutor for your goals, budget, and learning style. Key factors, questions to ask, and red flags to avoid.",
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": "2025-06-01",
  "dateModified": "2025-06-01"
};
---

<Base title="How to Choose an English Tutor: The Complete Guide (2025)" description="Learn how to find the perfect English tutor for your goals, budget, and learning style. Key factors, questions to ask, and red flags to avoid.">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  
  <Header />
  
  <main class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="text-sm text-gray-500 mb-4">
      <a href="/" class="hover:text-emerald-600">Home</a>
      <span class="mx-2">›</span>
      <a href="/guides" class="hover:text-emerald-600">Study Guides</a>
      <span class="mx-2">›</span>
      <span class="text-gray-700">How to Choose an English Tutor</span>
    </nav>

    <!-- Hero -->
    <div class="bg-gradient-to-r from-emerald-600 to-teal-600 rounded-2xl p-8 text-white mb-8">
      <span class="text-emerald-200 text-sm font-medium">Study Guide</span>
      <h1 class="text-4xl font-bold mt-2 mb-4">How to Choose an English Tutor: The Complete Guide</h1>
      <p class="text-emerald-100 text-lg mb-6">Finding the right tutor can accelerate your learning by months. This guide covers everything you need to know to make the best choice.</p>
    </div>

    <!-- TL;DR -->
    <div class="bg-amber-50 border-l-4 border-amber-400 p-4 rounded-r-lg mb-8">
      <h2 class="font-semibold text-amber-800">TL;DR</h2>
      <p class="text-amber-700">The best tutor depends on your budget (community tutors $4-10/hr, pro tutors $15-50/hr), goals (conversation, business, exam prep), and schedule. Always trial 1-2 lessons before committing.</p>
    </div>

    <AdUnit slot="guide-header" />

    <!-- Key Factors -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-6">Key Factors to Consider</h2>
      <div class="grid md:grid-cols-2 gap-4">
        {factors.map(factor => (
          <div class="bg-white rounded-xl shadow-sm p-6">
            <div class="text-3xl mb-3">{factor.icon}</div>
            <h3 class="font-bold text-lg mb-2">{factor.title}</h3>
            <p class="text-gray-600">{factor.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Platform Comparison -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-6">Where to Find Tutors</h2>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse bg-white rounded-xl shadow-sm">
          <thead>
            <tr class="bg-gray-50">
              <th class="text-left p-4">Platform</th>
              <th class="text-center p-4">Price Range</th>
              <th class="text-left p-4">Best For</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="p-4 font-semibold text-emerald-700"><a href="/reviews/italki/">iTalki</a></td>
              <td class="p-4 text-center">$4-50/hr</td>
              <td class="p-4">Community tutors, casual learners, budget-friendly</td>
            </tr>
            <tr class="bg-gray-50">
              <td class="p-4 font-semibold text-emerald-700"><a href="/reviews/preply/">Preply</a></td>
              <td class="p-4 text-center">$10-45/hr</td>
              <td class="p-4">Professional tutors, structured learning</td>
            </tr>
            <tr>
              <td class="p-4 font-semibold text-emerald-700"><a href="/reviews/cambly/">Cambly</a></td>
              <td class="p-4 text-center">$6.50-80/wk</td>
              <td class="p-4">Unlimited conversation practice, subscription model</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Self-Assessment -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-6">Questions to Ask Yourself First</h2>
      <div class="bg-white rounded-xl shadow-sm p-6">
        <ul class="space-y-3">
          {questions.map((q, i) => (
            <li class="flex items-start gap-3">
              <span class="bg-emerald-100 text-emerald-700 w-7 h-7 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0">{i + 1}</span>
              <span class="text-gray-700">{q}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <AdUnit slot="guide-mid" />

    <!-- Red Flags -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-6">Red Flags to Watch For</h2>
      <div class="space-y-3">
        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-r-lg">
          <h3 class="font-semibold text-red-800">Promises to make you fluent in weeks</h3>
          <p class="text-red-700 text-sm">Language learning takes time. Anyone promising miracles is misleading you.</p>
        </div>
        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-r-lg">
          <h3 class="font-semibold text-red-800">No reviews or only 5-star reviews</h3>
          <p class="text-red-700 text-sm">Real tutors have a mix of reviews. Perfect scores are suspicious.</p>
        </div>
        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-r-lg">
          <h3 class="font-semibold text-red-800">Refuses trial lessons</h3>
          <p class="text-red-700 text-sm">Legitimate tutors offer trial lessons. Be wary of those who do not.</p>
        </div>
        <div class="bg-red-50 border-l-4 border-red-400 p-4 rounded-r-lg">
          <h3 class="font-semibold text-red-800">Cannot explain their teaching method</h3>
          <p class="text-red-700 text-sm">Good tutors have a structured approach, not just random conversation.</p>
        </div>
      </div>
    </section>

    <!-- How to Evaluate -->
    <section class="mb-10">
      <h2 class="text-2xl font-bold mb-6">How to Evaluate Your First Lesson</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-green-50 rounded-xl p-5">
          <h3 class="font-semibold text-green-800 mb-3">Good Signs</h3>
          <ul class="text-green-700 space-y-2 text-sm">
            <li>They assessed your level first</li>
            <li>They asked about your goals</li>
            <li>They corrected your mistakes patiently</li>
            <li>You felt comfortable speaking</li>
            <li>They gave homework or resources</li>
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-5">
          <h3 class="font-semibold text-red-800 mb-3">Warning Signs</h3>
          <ul class="text-red-700 space-y-2 text-sm">
            <li>Just talked without interaction</li>
            <li>Did not correct errors</li>
            <li>No lesson plan or structure</li>
            <li>Made you feel nervous or judged</li>
            <li>No clear next steps</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-gradient-to-r from-emerald-500 to-teal-500 rounded-xl p-6 text-white mb-8">
      <h2 class="text-xl font-bold mb-3">Ready to Find Your Tutor?</h2>
      <p class="text-emerald-100 mb-4">Start with community tutors on iTalki for affordable practice, or browse professional teachers on Preply for structured lessons.</p>
      <div class="flex flex-wrap gap-3">
        <a href="/reviews/italki/" class="bg-white text-emerald-700 px-5 py-2 rounded-lg font-semibold hover:bg-emerald-50">Compare iTalki Tutors</a>
        <a href="/reviews/preply/" class="border-2 border-white text-white px-5 py-2 rounded-lg font-semibold hover:bg-white/10">Compare Preply Tutors</a>
      </div>
    </section>

    <!-- Related -->
    <section>
      <h2 class="text-xl font-bold mb-4">Continue Learning</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="/compare/best-english-learning-apps/" class="bg-white rounded-xl shadow-sm p-4 hover:shadow-md transition">
          <h3 class="font-semibold text-emerald-700">Best English Learning Apps</h3>
          <p class="text-gray-500 text-sm mt-1">Top apps to supplement tutor sessions</p>
        </a>
        <a href="/guides/free-vs-paid-english-learning/" class="bg-white rounded-xl shadow-sm p-4 hover:shadow-md transition">
          <h3 class="font-semibold text-emerald-700">Free vs Paid Resources</h3>
          <p class="text-gray-500 text-sm mt-1">Get the most value from your learning budget</p>
        </a>
      </div>
    </section>

  </main>

  <Footer />
</Base>
