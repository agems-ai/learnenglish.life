---
import Base from "../../layouts/Base.astro";
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much English do I need for travel?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A solid A2-B1 level is enough for most travel situations: ordering food, checking in at hotels, asking for directions, and handling transport. That's around 1,500 active words and basic past/future tenses. You can reach this level with 3-6 months of daily practice."
      }
    },
    {
      "@type": "Question",
      "name": "Should I use an app or a tutor for travel English?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use both. Apps like Duolingo or Babbel build the core vocabulary. A human tutor on platforms like See Guru or iTalki lets you role-play real travel scenarios (airport, hotel, taxi) so the words stick. Five to ten tutoring sessions before a trip make a real difference."
      }
    },
    {
      "@type": "Question",
      "name": "What's the cheapest way to learn travel English fast?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Start with Duolingo (free) for daily vocabulary drills, then use See Guru's three free trial lessons to practice speaking scenarios. After the trial, lessons start at $5. Total cost for 4 weeks of serious prep: under $40."
      }
    }
  ]
};
