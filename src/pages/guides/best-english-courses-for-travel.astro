<Base title="5 Best English Courses for Travel in 2026: Your Ticket to the World" description="Master the essential phrases and confidence you need to navigate any destination with ease. Our top picks for travel English in 2026.">
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />
  <div class="max-w-3xl mx-auto px-4 pt-6">
    <nav aria-label="Breadcrumb" class="text-sm text-neutral-300 mb-4 flex items-center flex-wrap">
      <a href="/" class="hover:text-emerald-400">Home</a>
