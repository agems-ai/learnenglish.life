        <li><a href="#start-your-ielts-prep-today" class="text-emerald-400 hover:text-emerald-300 hover:underline">Start Your IELTS Prep Today</a></li>
      </ol>
    </nav>
        <h2 class="text-2xl font-bold text-emerald-300 mb-2" id="italki-ielts">iTalki IELTS</h2>
        <div class="flex items-center gap-4 flex-wrap">
          <div class="text-4xl font-bold text-green-700">$8<span class="text-lg text-gray-400 font-normal">/session</span></div>
          <div class="flex gap-3">
