---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';

const categories = [
 {
  name: "Fundamentals",
  description: "Build your base. Grammar, common mistakes, and study habits.",
  guides: [
    { title: "English Grammar Basics", description: "The core rules every learner needs in their first 90 days. Tenses, articles, prepositions explained simply.", href: "/guides/english-grammar-basics/", readTime: "12 min", level: "Beginner" },
    { title: "Common English Mistakes", description: "The 30 errors most non-native speakers make. Spot them in your own writing and fix them for good.", href: "/guides/common-english-mistakes/", readTime: "9 min", level: "Intermediate" },
    { title: "How to Practice Speaking Alone", description: "Build fluency without a partner. Shadowing, self-talk, and recording techniques that work.", href: "/guides/how-to-practice-speaking-alone/", readTime: "8 min", level: "All Levels" },
  ]
 },
 {
  name: "Choose a Tutor or Platform",
  description: "Find the right 1-on-1 teacher for your level and budget.",
  guides: [
    { title: "How to Choose the Right Tutor", description: "Cut through the marketing. Questions to ask, red flags to spot, and how to test-drive a tutor.", href: "/guides/how-to-choose-english-tutor/", readTime: "10 min", level: "All Levels" },
    { title: "Best 1-on-1 English Tutoring 2026", description: "Our ranked list of the top 1-on-1 platforms for serious learners.", href: "/guides/best-1-on-1-english-tutoring-2026/", readTime: "10 min", level: "All Levels" },
    { title: "Cheapest 1-on-1 English Lessons Online", description: "Where to find real tutors under $10 a lesson without sacrificing quality.", href: "/guides/cheapest-1-on-1-english-lessons-online/", readTime: "7 min", level: "Budget" },
    { title: "How Much Does italki Cost?", description: "Real pricing breakdown — community tutors, pros, subscription plans.", href: "/guides/how-much-does-italki-cost/", readTime: "6 min", level: "Beginners+" },
    { title: "Online English Tutors Cost 2026", description: "What you'll actually pay across every major platform in 2026.", href: "/guides/online-english-tutors-cost-2026/", readTime: "8 min", level: "All Levels" },
    { title: "Best English Tutors for Beginners", description: "Where to start if you're new to 1-on-1 tutoring. Free trial options included.", href: "/guides/best-english-tutors-for-beginners/", readTime: "8 min", level: "Beginner" },
  ]
 },
 {
  name: "Goal-Specific Courses",
  description: "Business, IELTS, TOEFL, travel — pick a path with a clear outcome.",
  guides: [
    { title: "Best Business English Courses", description: "Structured courses for professionals who need to close deals and run meetings in English.", href: "/guides/best-business-english-courses/", readTime: "9 min", level: "B1+" },
    { title: "English Tutors for Business Professionals", description: "Top picks for executives, consultants, and founders working globally.", href: "/guides/english-tutors-business-professionals/", readTime: "8 min", level: "B1+" },
    { title: "Best English Tutors for IELTS Preparation", description: "Expert IELTS tutors who have helped learners hit Band 7+.", href: "/guides/best-english-tutors-ielts-preparation/", readTime: "9 min", level: "Exam" },
    { title: "IELTS Preparation Complete Guide", description: "What to study, what to skip, and a 12-week plan that actually moves your score.", href: "/guides/ielts-preparation-complete-guide/", readTime: "14 min", level: "Exam" },
    { title: "Best IELTS Prep Course 2026", description: "The top-rated IELTS courses for every budget.", href: "/guides/best-ielts-prep-course-2026/", readTime: "8 min", level: "Exam" },
    { title: "TOEFL Speaking Tips", description: "How to score higher on TOEFL speaking without sounding scripted.", href: "/guides/toefl-speaking-tips/", readTime: "7 min", level: "Exam" },
    { title: "TOEFL iBT vs Essentials", description: "Which test is right for you in 2026?", href: "/guides/toefl-ibt-vs-essentials/", readTime: "6 min", level: "Exam" },
    { title: "TOEFL Score Reporting", description: "How scores are sent, timing, and what universities actually see.", href: "/guides/toefl-score-reporting/", readTime: "5 min", level: "Exam" },
    { title: "Best Academic English Writing Course", description: "For university students and researchers writing in English.", href: "/guides/best-academic-english-writing-course/", readTime: "7 min", level: "Academic" },
    { title: "Best Medical English Courses", description: "For doctors, nurses, and healthcare professionals working internationally.", href: "/guides/best-medical-english-courses/", readTime: "7 min", level: "Specialist" },
    { title: "Best Course for Cabin Crew", description: "Prep for Emirates, Qatar, and other top airline interviews.", href: "/guides/best-english-course-for-cabin-crew/", readTime: "8 min", level: "Specialist" },
    { title: "Best English Courses for Travel", description: "Learn functional travel English in 4 weeks.", href: "/guides/best-english-courses-for-travel/", readTime: "7 min", level: "Beginner+" },
  ]
 },
 {
  name: "Apps, Kids & Free Resources",
  description: "Free options, kids' apps, and budget-friendly paths.",
  guides: [
    { title: "Best English Apps for Beginners", description: "Free and paid apps that take you from your first word to your first conversation.", href: "/guides/best-english-apps-for-beginners/", readTime: "7 min", level: "Beginner" },
    { title: "Best English Apps for Kids", description: "Game-based learning that keeps young learners engaged. Tested with kids 5–12.", href: "/guides/best-english-apps-for-kids/", readTime: "6 min", level: "Parents" },
    { title: "Best English Learning Apps 2026", description: "Our updated 2026 rankings of language learning apps.", href: "/guides/best-english-learning-apps-2026/", readTime: "9 min", level: "All Levels" },
    { title: "Best Free English Tutoring Apps", description: "Genuinely free options, with trade-offs called out honestly.", href: "/guides/best-free-english-tutoring-apps/", readTime: "7 min", level: "Free" },
    { title: "Free Online English Courses", description: "The best no-cost courses from universities, councils, and quality platforms.", href: "/guides/free-online-english-courses/", readTime: "8 min", level: "Free" },
    { title: "Free Trial English Lessons (No Credit Card)", description: "Platforms that give real free lessons with no card required.", href: "/guides/free-trial-english-lessons-no-credit-card/", readTime: "6 min", level: "Free" },
    { title: "Free vs Paid English Learning", description: "When free is enough, when paid is worth it, and how to mix both on a budget.", href: "/guides/free-vs-paid-english-learning/", readTime: "8 min", level: "All Levels" },
    { title: "Best English Course for Kids Online", description: "Structured kids' courses with tutors, safety, and measurable progress.", href: "/guides/best-english-course-for-kids-online/", readTime: "8 min", level: "Parents" },
  ]
 }
];
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://learnenglish.life/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://learnenglish.life/guides/" }
  ]
};

---
<Base title="English Study Guides | LearnEnglish.Life" description="Free study guides covering English grammar, common mistakes, speaking practice, choosing a tutor and the best learning apps. Built for self-directed learners.">
 <Header />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
 
 <!-- Hero -->
 <section class="bg-gradient-to-br from-emerald-950/60 to-teal-950/60 py-12">
 <div class="max-w-6xl mx-auto px-4 text-center">
 <h1 class="text-3xl md:text-4xl font-bold text-gray-100 mb-4">Free Study Guides
 </h1>
 <p class="text-lg text-slate-300 max-w-2xl mx-auto">Guides to master English grammar, vocabulary, and more. 
 all completely free.
 </p>
 </div>
 </section>

 <!-- Ad -->
 <div class="py-4 bg-neutral-800">
 <div class="max-w-6xl mx-auto px-4">
 <AdUnit slot="header" format="horizontal" />
 </div>
 </div>

 <!-- Guides by category -->
 <section class="py-12">
 <div class="max-w-6xl mx-auto px-4 space-y-14">
 {categories.map(category => (
 <div>
 <div class="mb-6 border-l-4 border-emerald-500 pl-4">
 <h2 class="text-2xl md:text-3xl font-bold text-white">{category.name}</h2>
 <p class="text-slate-300 mt-1">{category.description}</p>
 </div>
 <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
 {category.guides.map(guide => (
 <a href={guide.href} class="block bg-slate-900/60 rounded-xl border border-slate-700 hover:border-emerald-500 transition-colors group p-6">
 <h3 class="text-lg font-bold text-white mb-2 group-hover:text-emerald-300 transition-colors">
 {guide.title} →
 </h3>
 <p class="text-slate-300 text-sm mb-4">{guide.description}</p>
 <div class="flex items-center gap-3 text-xs text-slate-400">
 <span>{guide.readTime}</span>
 <span class="px-2 py-0.5 bg-slate-800 text-slate-300 rounded-full">
 {guide.level}
 </span>
 </div>
 </a>
 ))}
 </div>
 </div>
 ))}
 </div>
 </section>

 <!-- Ad -->
 <div class="py-8">
 <div class="max-w-6xl mx-auto px-4">
 <AdUnit slot="in-article" format="fluid" />
 </div>
 </div>

 <!-- CTA -->
 <section class="py-12 bg-gradient-to-br from-emerald-950/60 to-teal-950/40 border-y border-emerald-800/40">
 <div class="max-w-4xl mx-auto px-4 text-center">
  <div class="flex items-center justify-center gap-2 mb-3">
   <span class="text-yellow-400">★★★★★</span>
   <span class="text-emerald-300 font-bold">4.8 / 5</span>
  </div>
 <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">Ready for Personalized Learning?</h2>
 <p class="text-slate-200 mb-6 max-w-2xl mx-auto">Get 3 free lessons with a certified 1-on-1 tutor on See Guru. No credit card required, no strings attached.</p>
 <div class="flex flex-col sm:flex-row gap-3 justify-center">
 <a href="/go/see-guru/" rel="sponsored nofollow" class="inline-block px-6 py-3 bg-emerald-500 hover:bg-emerald-400 text-white font-semibold rounded-lg transition-colors">Try 3 Free Lessons →</a>
 <a href="/reviews/" class="inline-block px-6 py-3 bg-slate-900/60 text-white font-semibold rounded-lg border border-slate-700 hover:border-emerald-400 transition-colors">Browse Reviews</a>
 </div>
 </div>
 </section>

 <!-- AI Disclosure -->
 <section class="py-8 bg-gray-900/40">
 <div class="max-w-4xl mx-auto px-4 text-center">
 <p class="text-sm text-slate-400">
 </p>
 </div>
 </section>

 <Footer />
</Base>
