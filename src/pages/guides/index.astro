---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';

const guides = [
  {
    title: "English Grammar Guide",
    description: "Complete grammar reference from A1 to C2 level",
    icon: "📖",
    lessons: 45,
    level: "All Levels"
  },
  {
    title: "Vocabulary by Topic",
    description: "Essential words for travel, business, daily life, and more",
    icon: "📚",
    lessons: 30,
    level: "All Levels"
  },
  {
    title: "Business English",
    description: "Professional vocabulary and phrases for the workplace",
    icon: "💼",
    lessons: 25,
    level: "Intermediate+"
  },
  {
    title: "English for Travel",
    description: "Survive any trip with practical travel phrases",
    icon: "✈️",
    lessons: 20,
    level: "Beginner"
  },
  {
    title: "Pronunciation Mastery",
    description: "Master difficult sounds and improve fluency",
    icon: "🔊",
    lessons: 35,
    level: "All Levels"
  },
  {
    title: "Idioms & Expressions",
    description: "Sound more natural with common English idioms",
    icon: "💡",
    lessons: 40,
    level: "Intermediate+"
  },
];
---
<Base title="English Study Guides | LearnEnglish.Life">
  <Header />
  
  <!-- Hero -->
  <section class="bg-gradient-to-br from-emerald-950/60 to-teal-950/60 py-12">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-100 mb-4">
        Free Study Guides
      </h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto">
        Comprehensive guides to master English grammar, vocabulary, and more. 
        all completely free.
      </p>
    </div>
  </section>

  <!-- Ad -->
  <div class="py-4 bg-neutral-800">
    <div class="max-w-6xl mx-auto px-4">
      <AdUnit slot="header" format="horizontal" />
    </div>
  </div>

  <!-- Guides Grid -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {guides.map(guide => (
          <a href="#" class="bg-white rounded-xl p-6 shadow-sm border border-gray-700 hover:shadow-md hover:border-emerald-300 transition-all group">
            <span class="text-5xl mb-4 block">{guide.icon}</span>
            <h3 class="text-xl font-bold text-gray-100 mb-2 group-hover:text-emerald-600">
              {guide.title}
            </h3>
            <p class="text-gray-600 mb-4">{guide.description}</p>
            <div class="flex items-center gap-4 text-sm text-gray-500">
              <span>{guide.lessons} lessons</span>
              <span class="px-2 py-1 bg-gray-900/40 rounded-full text-xs">
                {guide.level}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Ad -->
  <div class="py-8">
    <div class="max-w-6xl mx-auto px-4">
      <AdUnit slot="in-article" format="fluid" />
    </div>
  </div>

  <!-- CTA -->
  <section class="py-12 bg-emerald-600">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">
        Ready for Personalized Learning?
      </h2>
      <p class="text-emerald-100 mb-6">
        Get matched with the perfect tutor or course for your goals.
      </p>
      <a href="/reviews/" class="inline-block px-6 py-3 bg-white text-emerald-600 font-semibold rounded-lg hover:bg-gray-900/40">
        Find Your Platform
      </a>
    </div>
  </section>

  <!-- AI Disclosure -->
  <section class="py-8 bg-gray-900/40">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-sm text-gray-500">
        <strong>AI Disclosure:</strong> LearnEnglish.Life is operated entirely by AI systems. 
        <a href="/about/" class="text-emerald-600 hover:underline">Learn more about us</a>
      </p>
    </div>
  </section>

  <Footer />
</Base>
