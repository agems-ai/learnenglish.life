---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import HeroCTA from '../../components/HeroCTA.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import BenefitCards from '../../components/BenefitCards.astro';
import SocialProof from '../../components/SocialProof.astro';
import ComparisonHighlight from '../../components/ComparisonHighlight.astro';

const review = {
  title: "Preply Review",
  rating: 8.8,
  reviewCount: 8900,
  price: "From $10/hr",
  heroTitle: "Learn English with a Structured Plan That Works",
  heroSubtitle: "Preply's learning path adapts to your goals. Get matched with a certified tutor and track your progress every week.",
  description: "Preply connects you with professional language tutors for 1-on-1 video lessons. With certified teachers and personalized learning plans, it's ideal for structured English learning.",
  publishedTime: "2026-01-06",
  pros: [
    "Follow a clear path from beginner to fluent",
    "Test 3 tutors before deciding. no pressure",
    "Learn from TEFL-certified professionals",
    "See your improvement every single week",
    "Weekly, monthly, or pay-as-you-go"
  ],
  cons: [
    "Premium pricing vs community tutors",
    "Quality varies by teacher",
    "Credit system can be confusing"
  ],
  ctaPrimary: "Find Your Perfect Tutor",
  ctaSecondary: "Start Your Free Trial",
  ctaLink: "/go/preply"
};

// Benefits specific to Preply
const benefits = [
  { icon: "📚", title: "Structured Learning Path", description: "Follow a clear curriculum from beginner to advanced level" },
  { icon: "🎓", title: "TEFL-Certified Teachers", description: "All professional tutors verified for teaching qualifications" },
  { icon: "📊", title: "Track Your Progress", description: "See measurable improvement week by week" },
  { icon: "💼", title: "Business English", description: "Specialized courses for professional communication" }
];

// Preply testimonials
const testimonials = [
  {
    quote: "Preply's structured approach finally got me to B2 level after 2 years of struggling with apps.",
    author: "Ahmed K.",
    location: "Egypt",
    result: "Achieved B2 in 8 months"
  },
  {
    quote: "My tutor created a custom curriculum for my job interviews. Landed the position at a US company!",
    author: "Sofia M.",
    location: "Spain",
    result: "Got hired by US company"
  },
  {
    quote: "The trial lesson system is genius. Found my perfect tutor within 3 tries.",
    author: "Thomas L.",
    location: "Germany",
    result: "IELTS 6.5 → 7.5"
  }
];

// Comparison table data with winner highlighting
const comparisonRows = [
  { feature: "Price Range", winner: null, a: "$5-40/hr", b: "$10-45/hr" },
  { feature: "Certified Teachers", winner: "b", a: "Limited", b: "All Professional" },
  { feature: "Trial Lessons", winner: "b", a: "Community", b: "Discounted First" },
  { feature: "Structured Curriculum", winner: "b", a: "No", b: "Yes" },
  { feature: "Progress Tracking", winner: "b", a: "Basic", b: "Advanced" }
];

const fullStars = Math.floor(review.rating / 2);

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": "Preply",
    "applicationCategory": "EducationApplication"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "8.8",
    "bestRating": "10",
    "worstRating": "1"
  },
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": review.publishedTime
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://learnenglish.life" },
    { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://learnenglish.life/reviews" },
    { "@type": "ListItem", "position": 3, "name": "Preply" }
  ]
};
---

<Base title="Preply Review 2026 | LearnEnglish.Life" description={review.description} type="article" publishedTime={review.publishedTime}>

  <span slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <ArticleSchema title={review.title} description={review.description} publishedTime={review.publishedTime} />
  </span>

  <Header />
  
  <!-- Breadcrumb -->
  <nav class="bg-neutral-800 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm">
      <ol class="flex items-center gap-2 text-neutral-300">
        <li><a href="/" class="hover:text-indigo-600">Home</a></li>
        <li>/</li>
        <li><a href="/reviews/" class="hover:text-indigo-600">Reviews</a></li>
        <li>/</li>
        <li class="text-white">Preply</li>
      </ol>
    </div>
  </nav>

  <!-- Hero CTA Section -->
  <div class="max-w-4xl mx-auto px-4 pt-6">
    <HeroCTA 
      platform="preply"
      rating={review.rating}
      reviewCount={review.reviewCount}
      price={review.price}
      ctaText={review.ctaPrimary}
      ctaLink={review.ctaLink}
      title={review.heroTitle}
      subtitle={review.heroSubtitle}
    />
  </div>

  <!-- Affiliate Disclosure -->
  <div class="bg-amber-900/30 border-b border-amber-700 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm text-amber-200">
      <strong>Affiliate Disclosure:</strong> We may earn a commission when you sign up through our links, at no extra cost to you. Our reviews remain unbiased.
    </div>
  </div>

  <!-- Main Content -->
  <article class="pb-24">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Benefit Cards -->
      <BenefitCards 
        title="Why Learners Choose Preply"
        benefits={benefits}
      />

      <!-- Social Proof Testimonials -->
      <SocialProof 
        title="Real Results from Real Learners"
        testimonials={testimonials}
      />

      <!-- Ad -->
      <div class="mb-8">
        <AdUnit slot="in-article" format="horizontal" />
      </div>

      <!-- Pros & Cons -->
      <section class="mb-8 grid md:grid-cols-2 gap-6">
        <div class="bg-emerald-900/30 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">✅ Pros</h2>
          <ul class="space-y-3">
            {review.pros.map(pro => (
              <li class="flex items-start gap-3 text-neutral-300">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-900/30 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">⚠️ Cons</h2>
          <ul class="space-y-3">
            {review.cons.map(con => (
              <li class="flex items-start gap-3 text-neutral-300">
                <span class="text-red-500 font-bold">−</span>
                <span>{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Comparison Table with Winner Highlighting -->
      <ComparisonHighlight 
        title="Preply vs iTalki: Quick Comparison"
        platformA={{ name: "Preply", slug: "preply", link: "/go/preply" }}
        platformB={{ name: "iTalki", slug: "italki", link: "/go/italki" }}
        winner="a"
        rows={comparisonRows}
      />

      <!-- Ad -->
      <div class="mb-8">
        <AdUnit slot="in-article" format="fluid" />
      </div>

      <!-- Verdict -->
      <section class="bg-neutral-800 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-white mb-3">Our Verdict</h2>
        <p class="text-neutral-300">
          Preply earns an 8.8/10 rating for its commitment to quality education. If you want structured learning with verified, professional teachers. Preply is your best choice. It's particularly strong for business professionals, exam candidates, and anyone who thrives with a clear learning path.
        </p>
        <p class="mt-3 text-gray-300 font-medium">
          Start with a trial lesson and discover why 89,000+ learners have chosen Preply for their English journey.
        </p>
      </section>

      <!-- Final CTA -->
      <section class="bg-indigo-600 rounded-xl p-8 text-center">
        <h3 class="text-2xl font-bold text-white mb-2">Ready to try Preply?</h3>
        <p class="text-indigo-100 mb-6">Find your perfect tutor today.</p>
        <a href={review.ctaLink} class="inline-block px-8 py-4 bg-slate-900/60 text-indigo-600 font-bold rounded-lg hover:bg-neutral-800 transition-colors">
          {review.ctaSecondary}
        </a>
      </section>

      <!-- Final Disclosure -->
      <p class="text-sm text-slate-400 text-center mt-6">
        <strong>Editorial Note:</strong> Our reviews are based on research and user feedback, not compensation. 
        We may earn affiliate commissions from purchases made through links on this page.
        <a href="/affiliate-disclosure/" class="text-indigo-600 hover:underline">Learn more</a>
      </p>
    </div>
  </article>

  <!-- Sticky CTA for Mobile -->
  <StickyCTA 
    ctaText={review.ctaPrimary}
    ctaLink={review.ctaLink}
    platform="preply"
  />

  <Footer />
<!-- See Guru alternative callout -->
<aside class="my-12 max-w-3xl mx-auto px-4">
  <div class="bg-gradient-to-br from-emerald-900/40 to-teal-900/40 border border-emerald-700 rounded-2xl p-6 md:p-8">
    <div class="flex items-start gap-4">
      <div class="text-3xl flex-shrink-0">💡</div>
      <div class="flex-1">
        <h3 class="text-lg md:text-xl font-bold text-white mb-2">Looking for a different style of tutoring?</h3>
        <p class="text-slate-200 mb-4">See Guru is the only platform that gives you <strong class="text-emerald-300">three free trial lessons</strong> with real human tutors — not bots, not videos. Certified, diploma-holding English teachers, flexible scheduling, and lessons starting at $5 each. No subscription required.</p>
        <a href="https://see.guru/?aff=SG-SUAG151" target="_blank" rel="sponsored noopener" class="inline-block px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors">Get 3 Free Lessons →</a>
      </div>
    </div>
  </div>
</aside>

</Base>
