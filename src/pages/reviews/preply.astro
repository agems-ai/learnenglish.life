---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';

const review = {
  title: "Preply Review",
  rating: 8.8,
  reviewCount: 8900,
  price: "From $10/hr",
  heroTitle: "Learn English with a Structured Plan That Works",
  heroSubtitle: "Preply's learning path adapts to your goals. Get matched with a certified tutor and track your progress every week.",
  description: "Preply connects you with professional language tutors for 1-on-1 video lessons. With certified teachers and personalized learning plans, it's ideal for structured English learning.",
  publishedTime: "2026-01-06",
  pros: [
    "Follow a clear path from beginner to fluent",
    "Test 3 tutors before deciding — no pressure",
    "Learn from TEFL-certified professionals",
    "See your improvement every single week",
    "Weekly, monthly, or pay-as-you-go"
  ],
  cons: [
    "Premium pricing vs community tutors",
    "Quality varies by teacher",
    "Credit system can be confusing"
  ],
  ctaPrimary: "Find Your Perfect Tutor",
  ctaSecondary: "Start Your Free Trial",
  socialProof: "I tried apps for 2 years. Preply's structured approach finally got me to B2 level.",
  socialProofAuthor: "Ahmed K., Egypt"
};

const comparison = [
  { feature: "Price Range", italki: "$5-40/hr", preply: "$10-45/hr", cambly: "$6.50-80/wk" },
  { feature: "Tutors", italki: "10,000+", preply: "5,000+", cambly: "10,000+" },
  { feature: "Native Speakers", italki: "Yes", preply: "Yes", cambly: "Yes" },
  { feature: "Free Trial", italki: "Community", preply: "Limited", cambly: "7 min free" },
  { feature: "Mobile App", italki: "iOS/Android", preply: "iOS/Android", cambly: "iOS/Android" },
];

const fullStars = Math.floor(review.rating / 2);

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": "Preply",
    "applicationCategory": "EducationApplication"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "8.8",
    "bestRating": "10",
    "worstRating": "1"
  },
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": review.publishedTime
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://learnenglish.life" },
    { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://learnenglish.life/reviews" },
    { "@type": "ListItem", "position": 3, "name": "Preply" }
  ]
};
---
<Base title="Preply Review 2026 | LearnEnglish.Life" description={review.description} type="article" publishedTime={review.publishedTime}>

  <span slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <ArticleSchema title={review.title} description={review.description} publishedTime={review.publishedTime} />
  </span>

  <Header />
  
  <!-- Breadcrumb -->
  <nav class="bg-gray-50 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/" class="hover:text-indigo-600">Home</a></li>
        <li>/</li>
        <li><a href="/reviews/" class="hover:text-indigo-600">Reviews</a></li>
        <li>/</li>
        <li class="text-gray-900">Preply</li>
      </ol>
    </div>
  </nav>

  <!-- Rating Overview -->
  <div class="bg-indigo-600 py-8">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">{review.heroTitle}</h1>
          <p class="text-indigo-100 text-lg mb-3">{review.heroSubtitle}</p>
          <div class="flex items-center gap-2">
            <div class="flex">
              {Array.from({length: 5}).map((_, i) => (
                <svg class={`w-6 h-6 ${i < fullStars ? 'text-yellow-400' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-xl text-white font-semibold">{review.rating}/10</span>
          </div>
          <p class="text-indigo-100 mt-2">Based on {review.reviewCount.toLocaleString()} reviews</p>
        </div>
        <div class="text-center md:text-right">
          <p class="text-sm text-indigo-200">Starting from</p>
          <p class="text-3xl font-bold text-white">{review.price}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Affiliate Disclosure -->
  <div class="bg-amber-50 border-b border-amber-200 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm text-amber-800">
      <strong>Affiliate Disclosure:</strong> We may earn a commission when you sign up through our links, at no extra cost to you.
    </div>
  </div>

  <!-- Main Content -->
  <article class="py-8">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Social Proof -->
      <section class="mb-8">
        <div class="bg-gray-50 rounded-xl p-6">
          <p class="italic text-lg text-gray-700">"{review.socialProof}"</p>
          <p class="mt-2 text-sm text-gray-500">— {review.socialProofAuthor}</p>
        </div>
      </section>

      <div class="bg-indigo-50 border border-indigo-200 rounded-xl p-6 mb-8 text-center">
        <a href="/go/preply" class="inline-block px-8 py-4 bg-indigo-600 text-white font-bold rounded-lg hover:bg-indigo-700">
          {review.ctaPrimary} →
        </a>
        <p class="text-sm text-gray-600 mt-2">Trial lessons available</p>
      </div>

      <div class="mb-8"><AdUnit slot="in-article" format="horizontal" /></div>

      <section class="mb-8 grid md:grid-cols-2 gap-6">
        <div class="bg-emerald-50 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-emerald-800 mb-4">✅ Pros</h2>
          <ul class="space-y-3">
            {review.pros.map(pro => (
              <li class="flex items-start gap-3 text-emerald-700">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-red-800 mb-4">⚠️ Cons</h2>
          <ul class="space-y-3">
            {review.cons.map(con => (
              <li class="flex items-start gap-3 text-red-700">
                <span class="text-red-500 font-bold">−</span>
                <span>{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">How Preply Compares</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse bg-white rounded-xl overflow-hidden shadow-sm">
            <thead>
              <tr class="bg-gray-100">
                <th class="text-left p-4 font-semibold">Feature</th>
                <th class="text-center p-4 font-semibold">iTalki</th>
                <th class="text-center p-4 font-semibold text-indigo-600">Preply</th>
                <th class="text-center p-4 font-semibold">Cambly</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              {comparison.map(row => (
                <tr class="hover:bg-gray-50">
                  <td class="p-4 font-medium">{row.feature}</td>
                  <td class="p-4 text-center">{row.italki}</td>
                  <td class="p-4 text-center">{row.preply}</td>
                  <td class="p-4 text-center">{row.cambly}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <div class="mb-8"><AdUnit slot="in-article" format="fluid" /></div>

      <section class="bg-gray-100 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-3">Our Verdict</h2>
        <p class="text-gray-700">Preply is excellent for learners who want certified, professional teachers and a structured curriculum. It's particularly strong for business English and professional development.</p>
      </section>

      <section class="bg-indigo-600 rounded-xl p-8 text-center">
        <h3 class="text-2xl font-bold text-white mb-2">Ready to try Preply?</h3>
        <p class="text-indigo-100 mb-6">Find your perfect tutor today.</p>
        <a href="/go/preply" class="inline-block px-8 py-4 bg-white text-indigo-600 font-bold rounded-lg hover:bg-gray-100">
          {review.ctaSecondary}
        </a>
      </section>

      <p class="text-sm text-gray-500 text-center mt-6">
        <a href="/affiliate-disclosure/" class="text-indigo-600 hover:underline">Affiliate disclosure</a>
      </p>
    </div>
  </article>

  <Footer />
</Base>