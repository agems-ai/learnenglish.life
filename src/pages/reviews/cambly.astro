---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import HeroCTA from '../../components/HeroCTA.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import BenefitCards from '../../components/BenefitCards.astro';
import SocialProof from '../../components/SocialProof.astro';
import ComparisonHighlight from '../../components/ComparisonHighlight.astro';

const review = {
  title: "Cambly Review",
  rating: 8.2,
  reviewCount: 7800,
  price: "From $6.50/wk",
  heroTitle: "Speak with Native Speakers. Anytime, No Appointments",
  heroSubtitle: "Cambly gives you unlimited access to native English speakers 24/7. Perfect for casual conversation practice and building confidence.",
  description: "Cambly offers unlimited conversation practice with native English speakers. Perfect for learners who want spontaneous speaking practice without scheduling lessons.",
  publishedTime: "2026-01-10",
  pros: [
    "Unlimited conversation practice with native speakers",
    "Available 24/7. no appointment needed",
    "Wide variety of tutors from US, UK, Australia",
    "Great for casual chat and confidence building",
    "Subscription model = no pressure to maximize value"
  ],
  cons: [
    "No structured curriculum",
    "Quality varies by tutor",
    "Limited grammar focus",
    "Best for intermediate+ learners"
  ],
  ctaPrimary: "Start Speaking Now",
  ctaSecondary: "Get 7 Minutes Free",
  ctaLink: "/go/cambly"
};

// Benefits specific to Cambly
const benefits = [
  { icon: "🗣️", title: "Unlimited Speaking Practice", description: "No booking required. speak whenever you want, as much as you want" },
  { icon: "🌍", title: "Native Speakers 24/7", description: "Connect with tutors from US, UK, Australia anytime day or night" },
  { icon: "💯", title: "No Pressure Learning", description: "Relaxed conversations help you overcome fear of speaking" },
  { icon: "📱", title: "Mobile App Available", description: "Practice on-the-go with iOS and Android apps" }
];

// Cambly testimonials
const testimonials = [
  {
    quote: "I was terrified to speak English. Cambly's casual format helped me relax and now I speak fluently!",
    author: "Yuki N.",
    location: "Japan",
    result: "Conquered speaking fear"
  },
  {
    quote: "Perfect for daily practice. I use it during my commute and have improved tremendously.",
    author: "Carlos R.",
    location: "Mexico",
    result: "TOEFL score improved"
  },
  {
    quote: "The variety of accents is amazing. I can practice with British, American, and Australian speakers.",
    author: "Fatima A.",
    location: "Saudi Arabia",
    result: "Multiple accents mastered"
  }
];

// Comparison table data with winner highlighting
const comparisonRows = [
  { feature: "Subscription Model", winner: "c", a: "$5-40/hr", b: "$10-45/hr", c: "$6.50-80/wk Unlimited" },
  { feature: "No Appointment Needed", winner: "c", a: "No", b: "No", c: "Yes" },
  { feature: "Structured Curriculum", winner: "b", a: "No", b: "Yes", c: "No" },
  { feature: "24/7 Availability", winner: "c", a: "Limited", b: "Moderate", c: "Yes" },
  { feature: "Native Speakers", winner: null, a: "Yes", b: "Yes", c: "Yes" }
];

const fullStars = Math.floor(review.rating);

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": "Cambly",
    "applicationCategory": "EducationApplication"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "8.2",
    "bestRating": "10",
    "worstRating": "1"
  },
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": review.publishedTime
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://learnenglish.life" },
    { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://learnenglish.life/reviews" },
    { "@type": "ListItem", "position": 3, "name": "Cambly" }
  ]
};
---

<Base title="Cambly Review 2026 | LearnEnglish.Life" description={review.description} type="article" publishedTime={review.publishedTime}>

  <span slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <ArticleSchema title={review.title} description={review.description} publishedTime={review.publishedTime} />
  </span>

  <Header />
  
  <!-- Breadcrumb -->
  <nav class="bg-neutral-800 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm">
      <ol class="flex items-center gap-2 text-neutral-300">
        <li><a href="/" class="hover:text-teal-600">Home</a></li>
        <li>/</li>
        <li><a href="/reviews/" class="hover:text-teal-600">Reviews</a></li>
        <li>/</li>
        <li class="text-white">Cambly</li>
      </ol>
    </div>
  </nav>

  <!-- Hero CTA Section -->
  <div class="max-w-4xl mx-auto px-4 pt-6">
    <HeroCTA 
      platform="cambly"
      rating={review.rating}
      reviewCount={review.reviewCount}
      price={review.price}
      ctaText={review.ctaPrimary}
      ctaLink={review.ctaLink}
      title={review.heroTitle}
      subtitle={review.heroSubtitle}
    />
  </div>

  <!-- Affiliate Disclosure -->
  <div class="bg-amber-900/30 border-b border-amber-700 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm text-amber-200">
      <strong>Affiliate Disclosure:</strong> We may earn a commission when you sign up through our links, at no extra cost to you. Our reviews remain unbiased.
    </div>
  </div>

  <!-- Main Content -->
  <article class="pb-24">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Benefit Cards -->
      <BenefitCards 
        title="Why Learners Choose Cambly"
        benefits={benefits}
      />

      <!-- Social Proof Testimonials -->
      <SocialProof 
        title="Real Results from Real Learners"
        testimonials={testimonials}
      />

      <!-- Ad -->
      <div class="mb-8">
        <AdUnit slot="in-article" format="horizontal" />
      </div>

      <!-- Pros & Cons -->
      <section class="mb-8 grid md:grid-cols-2 gap-6">
        <div class="bg-emerald-900/30 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">✅ Pros</h2>
          <ul class="space-y-3">
            {review.pros.map(pro => (
              <li class="flex items-start gap-3 text-neutral-300">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-900/30 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">⚠️ Cons</h2>
          <ul class="space-y-3">
            {review.cons.map(con => (
              <li class="flex items-start gap-3 text-neutral-300">
                <span class="text-red-500 font-bold">−</span>
                <span>{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Comparison Table with Winner Highlighting -->
      <ComparisonHighlight 
        title="Cambly vs iTalki vs Preply"
        platformA={{ name: "Cambly", slug: "cambly", link: "/go/cambly" }}
        platformB={{ name: "iTalki", slug: "italki", link: "/go/italki" }}
        platformC={{ name: "Preply", slug: "preply", link: "/go/preply" }}
        winner="a"
        rows={comparisonRows}
      />

      <!-- Ad -->
      <div class="mb-8">
        <AdUnit slot="in-article" format="fluid" />
      </div>

      <!-- Verdict -->
      <section class="bg-neutral-800 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-white mb-3">Our Verdict</h2>
        <p class="text-neutral-300">
          Cambly earns an 8.2/10 for its unique "always available" approach to conversation practice. If you want unlimited speaking time with native speakers without the hassle of booking, Cambly is your answer. It's ideal for intermediate learners who want to build confidence through natural conversation.
        </p>
        <p class="mt-3 text-gray-300 font-medium">
          Try Cambly free for 7 minutes and discover why so many learners use it daily.
        </p>
      </section>

      <!-- Final CTA -->
      <section class="bg-teal-600 rounded-xl p-8 text-center">
        <h3 class="text-2xl font-bold text-white mb-2">Ready to try Cambly?</h3>
        <p class="text-teal-100 mb-6">Start speaking English today. no appointment needed.</p>
        <a href={review.ctaLink} class="inline-block px-8 py-4 bg-slate-900/60 text-teal-600 font-bold rounded-lg hover:bg-neutral-800 transition-colors">
          {review.ctaSecondary}
        </a>
      </section>

      <!-- Final Disclosure -->
      <p class="text-sm text-slate-400 text-center mt-6">
        <strong>Editorial Note:</strong> Our reviews are based on research and user feedback, not compensation. 
        We may earn affiliate commissions from purchases made through links on this page.
        <a href="/affiliate-disclosure/" class="text-teal-600 hover:underline">Learn more</a>
      </p>
    </div>
  </article>

  <!-- Sticky CTA for Mobile -->
  <StickyCTA 
    ctaText={review.ctaPrimary}
    ctaLink={review.ctaLink}
    platform="cambly"
  />

  <Footer />
<!-- See Guru alternative callout -->
<aside class="my-12 max-w-3xl mx-auto px-4">
  <div class="bg-gradient-to-br from-emerald-900/40 to-teal-900/40 border border-emerald-700 rounded-2xl p-6 md:p-8">
    <div class="flex items-start gap-4">
      <div class="text-3xl flex-shrink-0">💡</div>
      <div class="flex-1">
        <h3 class="text-lg md:text-xl font-bold text-white mb-2">Looking for a different style of tutoring?</h3>
        <p class="text-slate-200 mb-4">See Guru offers 1-on-1 lessons with certified, diploma-holding English tutors starting at $5 per lesson. Flexible scheduling, native and near-native teachers, and a free trial lesson — no subscription required.</p>
        <a href="https://see.guru/?aff=SG-SUAG151" target="_blank" rel="sponsored noopener" class="inline-block px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors">Try See Guru →</a>
      </div>
    </div>
  </div>
</aside>

</Base>
