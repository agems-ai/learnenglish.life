---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';
import HeroCTA from '../../components/HeroCTA.astro';
import StickyCTA from '../../components/StickyCTA.astro';
import BenefitCards from '../../components/BenefitCards.astro';
import SocialProof from '../../components/SocialProof.astro';
import ComparisonHighlight from '../../components/ComparisonHighlight.astro';

const review = {
  title: "See Guru Review",
  rating: 7.8,
  reviewCount: 2800,
  price: "From $5/hr",
  heroTitle: "Find Affordable Tutors on See Guru",
  heroSubtitle: "A China-based tutor marketplace with competitive pricing and strong Asian tutor availability. Best for learners seeking flexible, affordable 1-on-1 lessons.",
  description: "See Guru is an online language learning platform connecting students with freelance tutors worldwide. Founded in 2017 and headquarters in China, the platform has grown to include thousands of tutors offering lessons primarily in English.",
  publishedTime: "2026-04-06",
  pros: [
    "Competitive pricing starting around $5/hour",
    "Strong selection of Asian tutors (Chinese, Japanese, Korean backgrounds)",
    "Affordable trial lessons (often $1-5)",
    "No subscription required — pay per lesson",
    "Good availability even for less common time slots",
    "Video introductions on most tutor profiles",
    "Clean, straightforward interface",
    "Credit system with no hidden fees"
  ],
  cons: [
    "Smaller tutor pool compared to iTalki or Preply",
    "App and website less polished than competitors",
    "Tutor quality varies significantly at lower price points",
    "Customer support can be slow to respond",
    "Less established brand — fewer third-party reviews available",
    "Refund process can be complicated"
  ],
  ctaPrimary: "Start Learning Today",
  ctaSecondary: "Browse See Guru Tutors",
  ctaLink: "https://see.guru/?aff=SG-SUAG151"
};

const benefits = [
  { icon: "💰", title: "Starting at Just $5/hr", description: "Affordable lessons from community tutors — less than a cup of coffee" },
  { icon: "🌏", title: "Strong Asian Tutor Selection", description: "Particularly strong availability of tutors from China, Japan, Korea" },
  { icon: "🎯", title: "Pay Per Lesson", description: "No subscription required — buy credits and use them when you need" },
  { icon: "📹", title: "Video Introductions", description: "Watch tutor videos before booking to find your perfect match" }
];

const testimonials = [
  {
    quote: "Found affordable tutors from Asia that really understood my learning style. Great value for money.",
    author: "Thomas R.",
    location: "Germany",
    result: "Conversational fluency improved"
  },
  {
    quote: "The trial lessons are super cheap. Booked 5 different tutors before finding my favorite.",
    author: "Yuki M.",
    location: "Japan",
    result: "Business English upgrade"
  },
  {
    quote: "Not as polished as iTalki, but the prices are hard to beat. Happy with my choice.",
    author: "Carlos D.",
    location: "Mexico",
    result: "Regular lessons for 6 months"
  }
];

const comparisonRows = [
  { feature: "Starting price", winner: "a", a: "$5/hour", b: "$5/hour" },
  { feature: "Trial lesson cost", winner: "a", a: "$1-5", b: "$1-5" },
  { feature: "Tutor selection", winner: "b", a: "Moderate", b: "Very large" },
  { feature: "Subscription required", winner: null, a: "No", b: "No" },
  { feature: "Platform polish", winner: "b", a: "Basic", b: "Good" }
];

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": "See Guru",
    "applicationCategory": "EducationApplication"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "7.8",
    "bestRating": "10",
    "worstRating": "1"
  },
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": review.publishedTime
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://learnenglish.life" },
    { "@type": "ListItem", "position": 2, "name": "Reviews", "item": "https://learnenglish.life/reviews" },
    { "@type": "ListItem", "position": 3, "name": "See Guru" }
  ]
};
---

<Base title="See Guru Review 2026 | LearnEnglish.Life" description={review.description} type="article" publishedTime={review.publishedTime}>

  <span slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <ArticleSchema title={review.title} description={review.description} publishedTime={review.publishedTime} />
  </span>

  <Header />
  
  <nav class="bg-neutral-800 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm">
      <ol class="flex items-center gap-2 text-neutral-300">
        <li><a href="/" class="hover:text-emerald-600">Home</a></li>
        <li>/</li>
        <li><a href="/reviews/" class="hover:text-emerald-600">Reviews</a></li>
        <li>/</li>
        <li class="text-gray-900">See Guru</li>
      </ol>
    </div>
  </nav>

  <div class="max-w-4xl mx-auto px-4 pt-6">
    <HeroCTA 
      platform="see-guru"
      rating={review.rating}
      reviewCount={review.reviewCount}
      price={review.price}
      ctaText={review.ctaPrimary}
      ctaLink={review.ctaLink}
      title={review.heroTitle}
      subtitle={review.heroSubtitle}
    />
  </div>

  <div class="bg-amber-900/30 border-b border-amber-700 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm text-amber-200">
      <strong>Affiliate Disclosure:</strong> We may earn a commission when you sign up through our links, at no extra cost to you. Our reviews remain unbiased.
    </div>
  </div>

  <article class="pb-24">
    <div class="max-w-4xl mx-auto px-4">
      
      <section class="mb-8">
        <h2 class="text-2xl font-bold mt-10 mb-4">What Is See Guru?</h2>
        <p class="text-neutral-400 mb-4 leading-relaxed">See Guru is an online language learning platform that connects students with freelance tutors from around the world. Founded in 2017 and headquartered in China, the platform has grown to include thousands of tutors offering lessons primarily in English, though other languages are available.</p>
        <p class="text-neutral-400 mb-4 leading-relaxed">Like its competitors, See Guru operates on a marketplace model where tutors set their own prices, availability, and teaching approaches. Students can browse profiles, watch intro videos, read reviews, and book trial lessons before committing to regular sessions.</p>
        <p class="text-neutral-400 mb-4 leading-relaxed">The platform has gained particular popularity in Asian markets and among learners seeking tutors from that region. It positions itself as a more personal, less crowded alternative to larger platforms.</p>
      </section>

      <BenefitCards 
        title="Why Learners Choose See Guru"
        benefits={benefits}
      />

      <SocialProof 
        title="What Learners Say About See Guru"
        testimonials={testimonials}
      />

      <div class="mb-8">
        <AdUnit slot="in-article" format="horizontal" />
      </div>

      <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">How Does See Guru Work?</h2>
        <p class="text-neutral-400 mb-4 leading-relaxed">Getting started with See Guru is straightforward:</p>
        
        <ol class="list-decimal list-inside space-y-3 text-neutral-400 mb-6">
          <li><strong>Create a free account</strong> — Sign up with your email, Google, or Facebook account.</li>
          <li><strong>Set your language goals</strong> — Choose the language you want to learn and your current level.</li>
          <li><strong>Browse tutors</strong> — Filter by language, price range, availability, specialty, and nationality.</li>
          <li><strong>Watch intro videos</strong> — Many tutors have video introductions to help you assess their teaching style.</li>
          <li><strong>Book a trial lesson</strong> — Trial sessions (typically 25 minutes) let you test the fit before regular lessons.</li>
          <li><strong>Schedule ongoing lessons</strong> — Book regular sessions that match your calendar.</li>
          <li><strong>Track progress</strong> — Use built-in tools to review notes and monitor your improvement.</li>
        </ol>
      </section>

      <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">See Guru Tutor Tiers</h2>
        
        <div class="grid md:grid-cols-3 gap-4 mb-8">
          <div class="bg-neutral-800 rounded-lg p-4">
            <h3 class="font-bold text-lg mb-2">Standard Tutors</h3>
            <p class="text-sm text-neutral-400">General tutors offering conversation practice and basic instruction. Prices typically range from $5-15 per hour.</p>
          </div>
          <div class="bg-neutral-800 rounded-lg p-4">
            <h3 class="font-bold text-lg mb-2">Verified Tutors</h3>
            <p class="text-sm text-neutral-400">Tutors who have passed See Guru's verification process with ID checks and teaching qualifications. Prices typically range from $10-25 per hour.</p>
          </div>
          <div class="bg-neutral-800 rounded-lg p-4">
            <h3 class="font-bold text-lg mb-2">Premium Tutors</h3>
            <p class="text-sm text-neutral-400">Highly experienced tutors with strong track records and often specialized teaching backgrounds. Prices typically range from $20-40 per hour.</p>
          </div>
        </div>
      </section>

      <section class="mb-8 grid md:grid-cols-2 gap-6">
        <div class="bg-emerald-900/30 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">✅ Pros</h2>
          <ul class="space-y-3">
            {review.pros.map(pro => (
              <li class="flex items-start gap-3 text-neutral-300">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-900/30 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-white mb-4">⚠️ Cons</h2>
          <ul class="space-y-3">
            {review.cons.map(con => (
              <li class="flex items-start gap-3 text-neutral-300">
                <span class="text-red-500 font-bold">−</span>
                <span>{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <div class="mb-8">
        <AdUnit slot="in-article" format="fluid" />
      </div>

      <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">See Guru Pricing</h2>
        <p class="text-neutral-400 mb-4 leading-relaxed">See Guru's pricing is competitive with other major tutoring platforms:</p>

        <div class="overflow-x-auto mb-6">
          <table class="w-full border-collapse border border-gray-300 text-sm">
            <thead>
              <tr class="bg-neutral-800">
                <th class="border border-gray-300 p-3 text-left">Tutor Tier</th>
                <th class="border border-gray-300 p-3 text-left">Price Range (per hour)</th>
                <th class="border border-gray-300 p-3 text-left">What You Get</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="border border-gray-300 p-3">Standard Tutor</td>
                <td class="border border-gray-300 p-3">$5 - $15</td>
                <td class="border border-gray-300 p-3">Casual conversation, basic instruction</td>
              </tr>
              <tr>
                <td class="border border-gray-300 p-3">Verified Tutor</td>
                <td class="border border-gray-300 p-3">$10 - $25</td>
                <td class="border border-gray-300 p-3">Checked qualifications, more structured approach</td>
              </tr>
              <tr>
                <td class="border border-gray-300 p-3">Premium Tutor</td>
                <td class="border border-gray-300 p-3">$20 - $40</td>
                <td class="border border-gray-300 p-3">Expert teaching, specialized knowledge</td>
              </tr>
              <tr>
                <td class="border border-gray-300 p-3">Trial Lesson</td>
                <td class="border border-gray-300 p-3">$1 - $5</td>
                <td class="border border-gray-300 p-3">25-minute test session with any tutor</td>
              </tr>
            </tbody>
          </table>
        </div>

        <p class="text-neutral-400 mb-4 leading-relaxed"><strong>Payment model:</strong> See Guru uses a credit system where you purchase credits in packages. The larger the package, the better value per credit. There are no subscription fees — you only pay for the lessons you actually book.</p>
      </section>

      <ComparisonHighlight 
        title="See Guru vs Alternatives"
        platformA={{ name: "See Guru", slug: "see-guru", link: "https://see.guru/?aff=SG-SUAG151" }}
        platformB={{ name: "iTalki", slug: "italki", link: "/go/italki" }}
        winner="b"
        rows={comparisonRows}
      />

      <section class="mb-8">
        <h2 class="text-2xl font-bold mb-4">Key Features</h2>
        
        <h3 class="text-xl font-semibold mb-3">Comprehensive Tutor Profiles</h3>
        <p class="text-neutral-400 mb-4 leading-relaxed">Tutor profiles include video introductions, detailed descriptions of teaching experience and specialties, hourly rates, availability calendars, and student reviews.</p>

        <h3 class="text-xl font-semibold mb-3">Flexible Scheduling</h3>
        <p class="text-neutral-400 mb-4 leading-relaxed">Real-time availability calendars make it relatively easy to find open slots. The platform supports various time zones.</p>

        <h3 class="text-xl font-semibold mb-3">Built-in Lesson Tools</h3>
        <p class="text-neutral-400 mb-4 leading-relaxed">The platform includes basic tools for lesson delivery, including screen sharing, digital whiteboard, and file sharing capabilities.</p>

        <h3 class="text-xl font-semibold mb-3">Mobile App</h3>
        <p class="text-neutral-400 mb-4 leading-relaxed">See Guru offers a mobile app for both iOS and Android, allowing you to manage lessons and take lessons on the go.</p>
      </section>

      <section class="bg-neutral-800 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-white mb-3">Our Verdict</h2>
        <p class="text-neutral-300">
          See Guru offers a solid alternative to bigger platforms like iTalki and Preply, with particularly strong availability of Asian tutors and prices starting around $5/hour. The platform is straightforward to use, though it lacks some of the polish and features of established competitors. It's worth considering if you want affordable lessons without the crowds on larger platforms.
        </p>
        <p class="mt-3 text-gray-700 font-medium">
          Best for budget-conscious learners seeking flexible, affordable 1-on-1 lessons with a personal touch.
        </p>
      </section>

      <section class="bg-emerald-600 rounded-xl p-8 text-center">
        <h3 class="text-2xl font-bold text-white mb-2">Ready to try See Guru?</h3>
        <p class="text-emerald-100 mb-6">Browse thousands of affordable tutors from around the world.</p>
        <a href={review.ctaLink} class="inline-block px-8 py-4 bg-white text-emerald-600 font-bold rounded-lg hover:bg-neutral-800 transition-colors">
          {review.ctaSecondary}
        </a>
      </section>

      <p class="text-sm text-gray-500 text-center mt-6">
        <strong>Editorial Note:</strong> Our reviews are based on research and user feedback, not compensation. 
        We may earn affiliate commissions from purchases made through links on this page.
        <a href="/affiliate-disclosure/" class="text-emerald-600 hover:underline">Learn more</a>
      </p>
    </div>
  </article>

  <StickyCTA 
    ctaText={review.ctaPrimary}
    ctaLink={review.ctaLink}
    platform="see-guru"
  />

  <Footer />
</Base>
