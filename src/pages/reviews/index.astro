---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReviewCard from '../../components/ReviewCard.astro';
import AdUnit from '../../components/AdUnit.astro';

const platforms = [
  { name: "iTalki", rating: 4.7, reviews: 12500, price: "From $10/hr", slug: "italki", category: "Tutoring" },
  { name: "Preply", rating: 4.6, reviews: 8900, price: "From $10/hr", slug: "preply", category: "Tutoring" },
  { name: "Cambly", rating: 4.4, reviews: 7200, price: "From $6.50/wk", slug: "cambly", category: "Conversation" },
  { name: "Verbling", rating: 4.5, reviews: 5400, price: "From $15/hr", slug: "verbling", category: "Tutoring" },
  { name: "iTalki", rating: 4.7, reviews: 12500, price: "From $10/hr", slug: "italki", category: "Tutoring" },
  { name: "Preply", rating: 4.6, reviews: 8900, price: "From $10/hr", slug: "preply", category: "Tutoring" },
  { name: "Cambly", rating: 4.4, reviews: 7200, price: "From $6.50/wk", slug: "cambly", category: "Conversation" },
  { name: "Verbling", rating: 4.5, reviews: 5400, price: "From $15/hr", slug: "verbling", category: "Tutoring" },
];

const categories = ["All", "Tutoring", "Conversation", "Courses", "Apps", "Games"];
---
<Base title="English Learning Platform Reviews | LearnEnglish.Life">
  <Header />
  
  <!-- Hero -->
  <section class="bg-emerald-600 py-12">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
        English Learning Platform Reviews
      </h1>
      <p class="text-emerald-100 text-lg">
        Honest, in-depth reviews of 50+ platforms based on real user experiences
      </p>
    </div>
  </section>

  <!-- Filters -->
  <section class="bg-white border-b py-4 sticky top-0 z-10">
    <div class="max-w-6xl mx-auto px-4">
      <div class="flex flex-wrap gap-2">
        {categories.map(cat => (
          <button class={`px-4 py-2 rounded-full text-sm font-medium transition-colors ${cat === 'All' ? 'bg-emerald-600 text-white' : 'bg-neutral-800 text-gray-700 hover:bg-gray-200'}`}>
            {cat}
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- Ad -->
  <div class="py-4 bg-neutral-800">
    <div class="max-w-6xl mx-auto px-4">
      <AdUnit slot="header" format="horizontal" />
    </div>
  </div>

  <!-- Reviews Grid -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {platforms.map(platform => (
          <ReviewCard 
            name={platform.name}
            rating={platform.rating}
            reviewCount={platform.reviews}
            price={platform.price}
            slug={platform.slug}
            category={platform.category}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Ad In-Feed -->
  <div class="py-8">
    <div class="max-w-6xl mx-auto px-4">
      <AdUnit slot="in-article" format="fluid" />
    </div>
  </div>

  <!-- More Reviews -->
  <section class="py-12 bg-neutral-800">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">More Platforms Coming Soon</h2>
      <p class="text-neutral-400 mb-4">
        We're continuously adding new reviews. Have a platform you'd like us to cover?
      </p>
      <a href="/contact/" class="text-emerald-600 font-semibold hover:underline">
        Request a Review →
      </a>
    </div>
  </section>

  <!-- AI Disclosure -->
  <section class="py-8 bg-neutral-800">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-sm text-gray-500">
        <strong>Editorial Integrity:</strong> Our reviews are based on thorough research and user feedback. 
        We may earn affiliate commissions from some links, but this never influences our ratings. 
        <a href="/affiliate-disclosure/" class="text-emerald-600 hover:underline">Learn more</a>
      </p>
    </div>
  </section>

  <Footer />
</Base>
