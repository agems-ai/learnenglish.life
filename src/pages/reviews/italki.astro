---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';
import ArticleSchema from '../../components/ArticleSchema.astro';

const review = {
  title: "iTalki Review",
  rating: 4.7,
  reviewCount: 12500,
  price: "From $10/hr",
  description: "iTalki is one of the largest online language learning platforms, connecting students with tutors from around the world. With over 10,000 teachers and flexible scheduling, it's a top choice for personalized English lessons.",
  publishedTime: "2026-01-08",
  pros: ["Large selection of tutors", "Flexible scheduling", "Community features for free practice", "Affordable trial lessons available"],
  cons: ["Quality varies between tutors", "Peak hour availability can be limited", "Occasional connection issues"]
};

const comparison = [
  { feature: "Price Range", italki: "$10-50/hr", preply: "$10-45/hr", cambly: "$6.50-80/wk" },
  { feature: "Tutors", italki: "10,000+", preply: "5,000+", cambly: "10,000+" },
  { feature: "Native Speakers", italki: "Yes", preply: "Yes", cambly: "Yes" },
  { feature: "Free Trial", italki: "Community", preply: "Limited", cambly: "7 min free" },
  { feature: "Mobile App", italki: "iOS/Android", preply: "iOS/Android", cambly: "iOS/Android" },
];

// Calculate stars
const fullStars = Math.floor(review.rating);

// Review Schema
const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": "iTalki",
    "applicationCategory": "EducationApplication"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "4.7",
    "bestRating": "10",
    "worstRating": "1"
  },
  "author": {
    "@type": "Organization",
    "name": "LearnEnglish.Life"
  },
  "datePublished": review.publishedTime
};

// Breadcrumb Schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://learnenglish.life"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Reviews",
      "item": "https://learnenglish.life/reviews"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "iTalki"
    }
  ]
};
---
<Base title="iTalki Review 2026 | LearnEnglish.Life" description={review.description} type="article" publishedTime={review.publishedTime}>

  <span slot="structured-data">
    <script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <ArticleSchema title={review.title} description={review.description} publishedTime={review.publishedTime} />
  </span>

  <Header />
  
  <!-- Breadcrumb -->
  <nav class="bg-gray-50 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm">
      <ol class="flex items-center gap-2 text-gray-500">
        <li><a href="/" class="hover:text-emerald-600">Home</a></li>
        <li>/</li>
        <li><a href="/reviews/" class="hover:text-emerald-600">Reviews</a></li>
        <li>/</li>
        <li class="text-gray-900">iTalki</li>
      </ol>
    </div>
  </nav>

  <!-- Rating Overview -->
  <div class="bg-emerald-600 py-8">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">iTalki Review</h1>
          <div class="flex items-center gap-2">
            <div class="flex">
              {Array.from({length: 5}).map((_, i) => (
                <svg class={`w-6 h-6 ${i < fullStars ? 'text-yellow-400' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <span class="text-xl text-white font-semibold">{review.rating}/5</span>
          </div>
          <p class="text-emerald-100 mt-2">Based on {review.reviewCount.toLocaleString()} reviews</p>
        </div>
        <div class="text-center md:text-right">
          <p class="text-sm text-emerald-200">Starting from</p>
          <p class="text-3xl font-bold text-white">{review.price}</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Affiliate Disclosure -->
  <div class="bg-amber-50 border-b border-amber-200 py-3">
    <div class="max-w-4xl mx-auto px-4 text-sm text-amber-800">
      <strong>Affiliate Disclosure:</strong> We may earn a commission when you sign up through our links, at no extra cost to you. Our reviews remain unbiased.
    </div>
  </div>

  <!-- Main Content -->
  <article class="py-8">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Description -->
      <section class="mb-8">
        <p class="text-lg text-gray-700 leading-relaxed">
          {review.description}
        </p>
      </section>

      <!-- CTA Button -->
      <div class="bg-emerald-50 border border-emerald-200 rounded-xl p-6 mb-8 text-center">
        <a href="/go/italki" class="inline-block px-8 py-4 bg-emerald-600 text-white font-bold rounded-lg hover:bg-emerald-700 transition-colors">
          Visit iTalki →
        </a>
        <p class="text-sm text-gray-600 mt-2">Free community access available</p>
      </div>

      <!-- Ad -->
      <div class="mb-8">
        <AdUnit slot="in-article" format="horizontal" />
      </div>

      <!-- Pros & Cons -->
      <section class="mb-8 grid md:grid-cols-2 gap-6">
        <div class="bg-emerald-50 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-emerald-800 mb-4">✅ Pros</h2>
          <ul class="space-y-3">
            {review.pros.map(pro => (
              <li class="flex items-start gap-3 text-emerald-700">
                <span class="text-emerald-500 font-bold">✓</span>
                <span>{pro}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="bg-red-50 rounded-xl p-6">
          <h2 class="text-lg font-semibold text-red-800 mb-4">⚠️ Cons</h2>
          <ul class="space-y-3">
            {review.cons.map(con => (
              <li class="flex items-start gap-3 text-red-700">
                <span class="text-red-500 font-bold">−</span>
                <span>{con}</span>
              </li>
            ))}
          </ul>
        </div>
      </section>

      <!-- Comparison Table -->
      <section class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-4">How iTalki Compares</h2>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse bg-white rounded-xl overflow-hidden shadow-sm">
            <thead>
              <tr class="bg-gray-100">
                <th class="text-left p-4 font-semibold">Feature</th>
                <th class="text-center p-4 font-semibold text-emerald-600">iTalki</th>
                <th class="text-center p-4 font-semibold">Preply</th>
                <th class="text-center p-4 font-semibold">Cambly</th>
              </tr>
            </thead>
            <tbody class="divide-y">
              {comparison.map(row => (
                <tr class="hover:bg-gray-50">
                  <td class="p-4 font-medium">{row.feature}</td>
                  <td class="p-4 text-center">{row.italki}</td>
                  <td class="p-4 text-center">{row.preply}</td>
                  <td class="p-4 text-center">{row.cambly}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <!-- Ad -->
      <div class="mb-8">
        <AdUnit slot="in-article" format="fluid" />
      </div>

      <!-- Verdict -->
      <section class="bg-gray-100 rounded-xl p-6 mb-8">
        <h2 class="text-xl font-bold text-gray-900 mb-3">Our Verdict</h2>
        <p class="text-gray-700">
          iTalki is our top choice for finding a personal English tutor. With thousands of teachers from around the world, 
          flexible scheduling, and options for every budget, you're sure to find someone who fits your learning style. 
          The community feature even lets you practice for free before committing to paid lessons.
        </p>
      </section>

      <!-- Final CTA -->
      <section class="bg-emerald-600 rounded-xl p-8 text-center">
        <h3 class="text-2xl font-bold text-white mb-2">Ready to try iTalki?</h3>
        <p class="text-emerald-100 mb-6">Join millions of learners improving their English.</p>
        <a href="/go/italki" class="inline-block px-8 py-4 bg-white text-emerald-600 font-bold rounded-lg hover:bg-gray-100">
          Get Started Free
        </a>
      </section>

      <!-- Final Disclosure -->
      <p class="text-sm text-gray-500 text-center mt-6">
        <strong>Editorial Note:</strong> Our reviews are based on research and user feedback, not compensation. 
        We may earn affiliate commissions from purchases made through links on this page.
        <a href="/affiliate-disclosure/" class="text-emerald-600 hover:underline">Learn more</a>
      </p>
    </div>
  </article>

  <Footer />
</Base>
