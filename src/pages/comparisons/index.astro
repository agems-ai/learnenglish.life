---
import Base from "../../layouts/Base.astro";
---
<Base title="Platform Comparisons. LearnEnglish.Life" description="Compare English learning platforms side-by-side. Find the best tutoring service for your needs and budget.">
  <section class="max-w-4xl mx-auto px-4 py-12">
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-slate-100 mb-4">Platform Comparisons</h1>
      <p class="text-lg text-slate-600">Compare English learning platforms side-by-side to find the best fit for you.</p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-12">
      <a href="/compare/italki-vs-preply/" class="bg-slate-900/60 rounded-xl border border-slate-700 p-6 hover:border-emerald-500 transition-colors hover:shadow-md">
        <h2 class="text-xl font-bold text-slate-100 mb-2">iTalki vs Preply</h2>
        <p class="text-slate-600 text-sm">Compare pricing, teacher quality, and features of two top tutoring platforms.</p>
      </a>
      <a href="/compare/preply-vs-cambly/" class="bg-slate-900/60 rounded-xl border border-slate-700 p-6 hover:border-emerald-500 transition-colors hover:shadow-md">
        <h2 class="text-xl font-bold text-slate-100 mb-2">Preply vs Cambly</h2>
        <p class="text-slate-600 text-sm">Find out which platform offers better value for your learning goals.</p>
      </a>
    </div>

    <div class="bg-amber-950/60 border border-amber-700 rounded-xl p-6">
      <p class="text-amber-200">
        <strong>More comparisons coming soon!</strong> Check back for head-to-head comparisons of all major English learning platforms.
      </p>
    </div>
  </section>
</Base>
