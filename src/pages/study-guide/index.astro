---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const guides = await getCollection('guides');
---

<Base title="Study Guides | LearnEnglish.Life" description="Free English study guides covering grammar, vocabulary, speaking practice, and more.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold text-slate-200 mb-4">Study Guides</h1>
    <p class="text-lg text-slate-600 mb-8">Free guides to help you master English. from grammar basics to conversation confidence.</p>
    
    <div class="grid gap-6">
      {guides.map(guide => (
        <a href={`/study-guide/${guide.slug}/`} class="block bg-slate-900/60 rounded-xl border border-slate-700 p-6 hover:shadow-lg transition-shadow">
          <h2 class="text-2xl font-bold text-slate-200 mb-2">{guide.data.title}</h2>
          <p class="text-slate-600">{guide.data.description}</p>
        </a>
      ))}
    </div>
  </div>
</Base>
