 </div>
 <script>var AFFILIATE_URL = "https://www.pimsleur.com/";
 setTimeout(() => { window.location.href = AFFILIATE_URL; }, 200);
 </script>
 <p style="margin-top:20px"><a href="https://www.pimsleur.com/" rel="noopener sponsored" style="color:#fff;text-decoration:underline;font-weight:600">Continue to Pimsleur</a></p>
</body>
</html>
