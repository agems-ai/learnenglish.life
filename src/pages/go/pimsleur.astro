<html lang="en">
<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <meta name="robots" content="noindex, nofollow">
 <meta http-equiv="refresh" content="0; url=https://www.pimsleur.com/">
 <title>Redirecting to Pimsleur...</title>
 <style>body { margin: 0; font-family: system-ui, sans-serif; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
 .container { text-align: center; color: white; }
 .logo { font-size: 48px; margin-bottom: 20px; }
 h1 { font-size: 24px; margin-bottom: 10px; }
 p { font-size: 16px; opacity: 0.9; }
 .loader { width: 40px; height: 40px; border: 3px solid rgba(255,255,255,0.3); border-top-color: white; border-radius: 50%; animation: spin 1s linear infinite; margin: 20px auto; }
