---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdUnit from '../../components/AdUnit.astro';

const posts = [
  {
    title: "5 Mistakes That Quietly Kill Your English Progress",
    excerpt: "The five quiet habits that hold most adult learners back, and the small changes that fix them. No fluff, no shopping list of apps.",
    category: "Habits",
    readTime: "8 min",
    date: "April 11, 2026",
    href: "/blog/5-mistakes-killing-your-english-progress/",
    image: "/blog/5-mistakes.jpg"
  },
  {
    title: "Why You Can't Speak English Yet (Even After Years of Study)",
    excerpt: "The real reason intermediate learners stall on speaking, even after years of grammar and vocab work, plus the one habit that breaks the silence.",
    category: "Speaking",
    readTime: "9 min",
    date: "April 11, 2026",
    href: "/blog/why-you-cant-speak-english-yet/",
    image: "/blog/cant-speak.jpg"
  },
  {
    title: "Free vs Paid English Resources: When Each One Actually Wins",
    excerpt: "Honest breakdown of where free resources beat paid ones, where they fail, and a hybrid plan that costs under $30 a month but works.",
    category: "Budget Guide",
    readTime: "10 min",
    date: "April 11, 2026",
    href: "/blog/free-vs-paid-english-resources/",
    image: "/blog/free-vs-paid.jpg"
  },
  {
    title: "What's the Best Time of Day to Study English?",
    excerpt: "What sleep science and language research say about morning vs evening study, plus a real schedule for working learners and parents on a tight day.",
    category: "Study Habits",
    readTime: "8 min",
    date: "April 11, 2026",
    href: "/blog/best-time-to-study-english/",
    image: "/blog/best-time.jpg"
  },
  {
    title: "How Long Does It Really Take to Learn English? A Reality Check",
    excerpt: "The honest answer with real CEFR study hours per level, why some learners get fluent in 6 months and others stall, and the fastest path from A1 to B2.",
    category: "Reality Check",
    readTime: "9 min",
    date: "April 11, 2026",
    href: "/blog/how-long-to-learn-english/",
    image: "/blog/how-long.jpg"
  },
  {
    title: "How to Practice English Speaking Alone",
    excerpt: "You don't need a textbook or a partner. Here are proven methods to practice English using just your phone and daily life.",
    category: "Tips",
    readTime: "5 min",
    date: "April 5, 2026",
    href: "/guides/how-to-practice-speaking-alone/",
    image: "/blog/speaking-alone.jpg"
  },
  {
    title: "iTalki vs Preply: Which is Better in 2026?",
    excerpt: "We compared pricing, teacher quality, and user experience. Here's what we found.",
    category: "Comparisons",
    readTime: "8 min",
    date: "April 3, 2026",
    href: "/compare/italki-vs-preply/",
    image: "/blog/italki-vs-preply.jpg"
  },
  {
    title: "How to Choose the Right English Tutor",
    excerpt: "Picking the right tutor changes everything. Our guide walks through the questions to ask and the red flags to watch.",
    category: "Tutoring",
    readTime: "6 min",
    date: "April 1, 2026",
    href: "/guides/how-to-choose-english-tutor/",
    image: "/blog/choose-tutor.jpg"
  },
  {
    title: "Best English Apps for Beginners",
    excerpt: "Starting from zero. These apps give the smoothest path from your first word to your first conversation.",
    category: "Resources",
    readTime: "4 min",
    date: "March 28, 2026",
    href: "/guides/best-english-apps-for-beginners/",
    image: "/blog/apps-beginners.jpg"
  },
];
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://learnenglish.life/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://learnenglish.life/blog/" }
  ]
};

---
<Base title="English Learning Blog | LearnEnglish.Life" description="Tips, study guides and platform news for learners. Practical articles on grammar, speaking, tutors, apps and getting fluent faster.">
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  
  <!-- Hero -->
  <section class="bg-gradient-to-br from-emerald-950 via-neutral-950 to-teal-950 py-12 border-b border-slate-800">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
        English Learning Blog
      </h1>
      <p class="text-slate-300 text-lg">
        Tips, guides, and the latest news in language learning
      </p>
    </div>
  </section>

  <!-- Ad -->
  <div class="py-4 bg-neutral-800">
    <div class="max-w-6xl mx-auto px-4">
      <AdUnit slot="header" format="horizontal" />
    </div>
  </div>

  <!-- Posts Grid -->
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-8">
        {posts.map(post => (
          <a href={post.href} class="block group bg-slate-900/60 rounded-xl border border-slate-700 overflow-hidden hover:border-emerald-500 transition-colors">
            <div class="h-48 overflow-hidden">
              <img src={post.image} alt={post.title} loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 text-sm text-slate-400 mb-3">
                <span class="px-2 py-1 bg-emerald-900/40 text-emerald-400 rounded-full text-xs font-medium">
                  {post.category}
                </span>
                <span>{post.readTime} read</span>
                <span>•</span>
                <span>{post.date}</span>
              </div>
              <h2 class="text-xl font-bold text-white mb-2 group-hover:text-emerald-300 transition-colors">
                {post.title}
              </h2>
              <p class="text-slate-300 mb-4">{post.excerpt}</p>
              <span class="text-emerald-400 font-semibold group-hover:text-emerald-300">
                Read More →
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Ad -->
  <div class="py-8">
    <div class="max-w-6xl mx-auto px-4">
      <AdUnit slot="in-article" format="fluid" />
    </div>
  </div>

  <!-- Reviews CTA -->
  <section class="py-12 bg-slate-950 border-y border-slate-800">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">Looking for the right platform?</h2>
      <p class="text-slate-200 mb-6">
        We've tested every major English learning service so you don't have to. See our full review library.
      </p>
      <a href="/reviews/" class="inline-block px-8 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors">
        Read more reviews →
      </a>
    </div>
  </section>

  <!-- AI Disclosure -->
  <section class="py-8 bg-gray-900/40">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-sm text-slate-400">
        </p>
    </div>
  </section>

  <Footer />
</Base>
