---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Base title="About Us | LearnEnglish.Life" description="Who we are and how LearnEnglish.Life reviews English learning platforms, tutors, courses and apps to help you make a confident choice.">
  <Header />
  
  <!-- Hero -->
  <section class="bg-emerald-700 py-12">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-3xl md:text-4xl font-bold text-white mb-2">
        About LearnEnglish.Life
      </h1>
      <p class="text-emerald-100 text-lg">
        Honest reviews and expert resources for English learners worldwide
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-12">
    <div class="max-w-4xl mx-auto px-4">

      <!-- Mission -->
      <h2 class="text-2xl font-bold text-gray-100 mb-4">Our Mission</h2>
      <p class="text-gray-300 mb-6 leading-relaxed">
        We believe everyone deserves access to quality English learning resources, regardless of budget or location. 
        Our mission is to help millions of learners find the right tools, methods, and motivation to master English.
      </p>

      <!-- How We Work -->
      <h2 class="text-2xl font-bold text-gray-100 mb-4 mt-8">How We Work</h2>
      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="bg-gray-950/60 rounded-xl p-6">
          <span class="text-4xl mb-4 block">📝</span>
          <h3 class="font-semibold text-gray-100 mb-2">Research & Review</h3>
          <p class="text-sm text-slate-300">
            We continuously research new platforms, tools, and methods to bring you up-to-date, accurate information.
          </p>
        </div>
        <div class="bg-gray-950/60 rounded-xl p-6">
          <span class="text-4xl mb-4 block">⚖️</span>
          <h3 class="font-semibold text-gray-100 mb-2">Honest Comparisons</h3>
          <p class="text-sm text-slate-300">
            We compare platforms fairly, highlighting both strengths and weaknesses. Our ratings are never influenced by payments.
          </p>
        </div>
        <div class="bg-gray-950/60 rounded-xl p-6">
          <span class="text-4xl mb-4 block">🛠️</span>
          <h3 class="font-semibold text-gray-100 mb-2">Free Tools</h3>
          <p class="text-sm text-slate-300">
            We offer free tools to help you practice English, regardless of your budget, including grammar checkers, vocabulary builders, and interactive games.
          </p>
        </div>
      </div>

      <!-- Editorial Standards -->
      <h2 class="text-2xl font-bold text-gray-100 mb-4 mt-8">Editorial Standards</h2>
      <ul class="space-y-3 text-gray-300 mb-8">
        <li class="flex items-start gap-3">
          <span class="text-emerald-600 font-bold">✓</span>
          <span><strong>No fabricated reviews:</strong> All reviews are based on research and user feedback, never invented.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-emerald-600 font-bold">✓</span>
          <span><strong>Affiliate transparency:</strong> We clearly disclose when links earn us commissions.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-emerald-600 font-bold">✓</span>
          <span><strong>No review manipulation:</strong> Affiliate relationships never affect our ratings or recommendations.</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="text-emerald-600 font-bold">✓</span>
          <span><strong>Corrections policy:</strong> We correct errors quickly when identified.</span>
        </li>
      </ul>

      <!-- Editorial Team -->
      <h2 class="text-2xl font-bold text-gray-100 mb-4 mt-8">Our Editorial Team</h2>
      <p class="text-gray-300 mb-6">
        LearnEnglish.Life is run by a dedicated team of specialists, each focused on a specific area of English learning:
      </p>
      <div class="grid md:grid-cols-2 gap-4 text-sm">
        <div class="bg-gray-950/60 rounded-lg p-4">
          <strong>Editorial & Content</strong>. Research, writing, and continuous review of all platform content
        </div>
        <div class="bg-gray-950/60 rounded-lg p-4">
          <strong>Product & Technology</strong>. Building and maintaining the site, tools, and user experience
        </div>
        <div class="bg-gray-950/60 rounded-lg p-4">
          <strong>Quality Assurance</strong>. Ensuring every review meets our accuracy and fairness standards
        </div>
        <div class="bg-gray-950/60 rounded-lg p-4">
          <strong>SEO & Growth</strong>. Helping learners discover the right resources through search and social
        </div>
      </div>

      <!-- Contact -->
      <h2 class="text-2xl font-bold text-gray-100 mb-4 mt-8">Contact Us</h2>
      <p class="text-gray-300 mb-4">
        Have questions, feedback, or want to suggest a platform for review?
      </p>
      <p class="text-gray-300">
        <strong>Email:</strong> hello@learnenglish.life<br />
        <strong>Note:</strong> As an independent publisher, we read and respond to all emails as quickly as possible.
      </p>
    </div>
  </section>

  <Footer />
</Base>
