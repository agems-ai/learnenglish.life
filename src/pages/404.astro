---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const popular = [
  { href: '/reviews/', title: 'All Platform Reviews', desc: 'Honest reviews of 50+ English tutoring platforms and apps.' },
  { href: '/compare/', title: 'Side-by-Side Comparisons', desc: 'Compare iTalki, Preply, Cambly, Lingoda and more.' },
  { href: '/guides/', title: 'Learning Guides', desc: 'Beginner, business, IELTS and exam-prep guides.' },
  { href: '/tools/', title: 'Free AI Practice Tools', desc: 'Grammar checker, vocabulary builder and speaking coach.' },
  { href: '/blog/', title: 'Learning Blog', desc: 'Fresh tips for learning English faster.' },
  { href: '/games/', title: 'English Games', desc: 'Word puzzles, quizzes and grammar challenges.' },
];
---
<Base
  title="Page Not Found (404) | LearnEnglish.Life"
  description="The page you're looking for doesn't exist. Browse our reviews, comparisons and free learning tools instead."
>
  <Header />

  <section class="py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <p class="text-sm font-semibold text-emerald-400 uppercase tracking-wider mb-3">Error 404</p>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-100 mb-4">Page Not Found</h1>
      <p class="text-lg text-slate-300 mb-10 max-w-xl mx-auto">
        We couldn't find the page you're looking for. It may have moved, been renamed, or never existed.
        Here are some helpful places to go instead.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-14">
        <a href="/" class="px-6 py-3 bg-emerald-600 text-white font-semibold rounded-lg hover:bg-emerald-500 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-emerald-400 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950">
          Go to Homepage
        </a>
        <a href="/reviews/" class="px-6 py-3 bg-slate-800 text-slate-100 font-semibold rounded-lg hover:bg-slate-700 transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-slate-400 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-950">
          Browse Reviews
        </a>
      </div>

      <h2 class="text-2xl font-bold text-white mb-6 text-left">Popular sections</h2>
      <div class="grid md:grid-cols-2 gap-4 text-left">
        {popular.map((item) => (
          <a
            href={item.href}
            class="block p-5 bg-neutral-900 border border-neutral-800 rounded-xl hover:border-emerald-600 hover:bg-neutral-900/80 transition-colors group"
          >
            <h3 class="text-lg font-semibold text-white mb-1 group-hover:text-emerald-400 transition-colors">
              {item.title}
            </h3>
            <p class="text-sm text-slate-300">{item.desc}</p>
          </a>
        ))}
      </div>

      <p class="mt-10 text-sm text-slate-400">
        Still can't find what you need? <a href="/contact/" class="text-emerald-400 hover:text-emerald-300 underline">Contact us</a>.
      </p>
    </div>
  </section>

  <Footer />
</Base>
