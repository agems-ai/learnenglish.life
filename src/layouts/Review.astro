---
import Base from '@/layouts/Base.astro';
import AdUnit from '@/components/AdUnit.astro';
import StarRating from '@/components/StarRating.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import ProsCons from '@/components/ProsCons.astro';
import PricingTable from '@/components/PricingTable.astro';
import RelatedReviews from '@/components/RelatedReviews.astro';
import UserReviews from '@/components/UserReviews.astro';
import { formatDate, calculateReadingTime } from '@/lib/utils';
import { generateSchemaMarkup } from '@/lib/seo';

interface Props {
  title: string;
  description: string;
  targetKeyword: string;
  aggregateRating: number;
  reviewCount: number;
  pros: string[];
  cons: string[];
  pricing: Array<{ name: string; price: string; features: string[] }>;
  affiliateDisclosure: string;
  affiliateLink: string;
  getStartedText?: string;
  publishedTime?: string;
  modifiedTime?: string;
  relatedReviews?: Array<{ title: string; slug: string; rating: number; image?: string }>;
  platformLogo?: string;
}

const {
  title,
  description,
  targetKeyword,
  aggregateRating,
  reviewCount,
  pros,
  cons,
  pricing,
  affiliateDisclosure,
  affiliateLink,
  getStartedText = 'Get Started',
  publishedTime = new Date().toISOString(),
  modifiedTime,
  relatedReviews = [],
  platformLogo,
} = Astro.props;

const readingTime = calculateReadingTime(description);
const schemaMarkup = generateSchemaMarkup({
  type: 'Review',
  data: {
    name: title,
    description,
    aggregateRating,
    reviewCount,
    itemReviewed: {
      '@type': 'SoftwareApplication',
      name: title,
    },
    author: {
      '@type': 'Organization',
      name: 'LearnEnglish.Life',
    },
    datePublished: publishedTime,
  },
});
---

<Base title={`${targetKeyword} Review`} description={description} type="article">
  <script type="application/ld+json" slot="head" set:html={schemaMarkup} />
  
  <article class="py-8 md:py-12">
    <div class="container-site">
      <!-- Breadcrumb -->
      <nav class="mb-6 text-sm" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-neutral-400">
          <li><a href="/" class="hover:text-brand-400">Home</a></li>
          <li><span class="mx-2">/</span></li>
          <li><a href="/reviews" class="hover:text-brand-400">Reviews</a></li>
          <li><span class="mx-2">/</span></li>
          <li class="text-white">{title}</li>
        </ol>
      </nav>

      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-8">
          <!-- Header -->
          <header class="space-y-4">
            {platformLogo && (
              <img 
                src={platformLogo} 
                alt={title} 
                class="h-16 w-auto object-contain"
                loading="lazy"
              />
            )}
            <h1 class="text-3xl md:text-4xl font-bold text-white">
              {title} Review
            </h1>
            
            <div class="flex flex-wrap items-center gap-4">
              <StarRating rating={aggregateRating} count={reviewCount} />
              <span class="text-neutral-400">
                {formatDate(publishedTime)} · {readingTime} min read
              </span>
            </div>

            <p class="text-lg text-neutral-300 leading-relaxed">
              {description}
            </p>

            <!-- Target Keyword Badge -->
            <div class="inline-block px-3 py-1 bg-brand-500/10 border border-brand-500/20 rounded-full">
              <span class="text-sm text-brand-400 font-medium">{targetKeyword}</span>
            </div>
          </header>

          <!-- Affiliate Disclosure -->
          <AffiliateDisclosure text={affiliateDisclosure} />

          <!-- Get Started CTA -->
          <div class="bg-gradient-to-r from-brand-500/20 to-brand-600/10 border border-brand-500/30 rounded-xl p-6">
            <div class="flex flex-col sm:flex-row items-center gap-4">
              <div class="flex-1">
                <h3 class="text-lg font-semibold text-white mb-1">
                  Ready to {getStartedText.toLowerCase()}?
                </h3>
                <p class="text-sm text-neutral-400">
                  Click below to visit {title} and start your learning journey.
                </p>
              </div>
              <a
                href={affiliateLink}
                target="_blank"
                rel="noopener noreferrer sponsored"
                class="btn-primary whitespace-nowrap"
              >
                {getStartedText} →
              </a>
            </div>
          </div>

          <!-- Ad Unit -->
          <AdUnit slot="header" format="in-article" />

          <!-- Pros & Cons -->
          <ProsCons pros={pros} cons={cons} />

          <!-- Ad Unit -->
          <AdUnit slot="middle" format="in-article" />

          <!-- More Content -->
          <slot />

          <!-- Ad Unit -->
          <AdUnit slot="footer" format="in-article" />

          <!-- User Reviews -->
          <UserReviews platform={title} />

          <!-- Final CTA -->
          <div class="bg-neutral-900 border border-neutral-800 rounded-xl p-6 text-center">
            <h3 class="text-xl font-semibold text-white mb-2">
              Start Learning with {title} Today
            </h3>
            <p class="text-neutral-400 mb-4">
              Join thousands of learners who have improved their English.
            </p>
            <a
              href={affiliateLink}
              target="_blank"
              rel="noopener noreferrer sponsored"
              class="btn-primary inline-flex"
            >
              {getStartedText} →
            </a>
          </div>

          <AffiliateDisclosure text={affiliateDisclosure} variant="compact" />
        </div>

        <!-- Sidebar -->
        <aside class="space-y-6">
          <PricingTable plans={pricing} />
          <!-- ADSENSE: SIDEBAR 300x250 -->
          <div class="bg-neutral-800 border border-neutral-600 rounded-lg flex items-center justify-center" style="width:300px; height:250px; margin:0 auto;">
            <span class="text-neutral-400 text-sm">Ad Placement: Sidebar (300x250)</span>
          </div>
          <RelatedReviews reviews={relatedReviews} />
        </aside>
      </div>
    </div>
  </article>
</Base>