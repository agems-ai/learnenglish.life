---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent';
import Analytics from '../components/Analytics.astro';
import SchemaInjector from '../components/SchemaInjector.astro';
import type { ArticleSchemaData, ReviewSchemaData, FAQSchemaData } from '../lib/seo';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  /** Article schema data — auto-generates Article JSON-LD */
  articleSchema?: ArticleSchemaData;
  /** Review schema data — auto-generates Review JSON-LD */
  reviewSchema?: ReviewSchemaData;
  /** FAQ schema data — auto-generates FAQPage JSON-LD */
  faqSchema?: FAQSchemaData;
  /** Additional custom JSON-LD schema objects */
  customSchemas?: object[];
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalUrl,
  type = 'website',
  publishedTime,
  modifiedTime,
  articleSchema,
  reviewSchema,
  faqSchema,
  customSchemas,
} = Astro.props;
const siteUrl = 'https://learnenglish.life';
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-adsense-account" content="ca-pub-7792548915836467" />

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-W42NG9QB');</script>
    <!-- End Google Tag Manager -->

    <!-- Google Analytics 4 (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q1D36CSBCC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q1D36CSBCC');
    </script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, siteUrl).href} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Auto-generated Structured Data (Organization + WebSite + BreadcrumbList + content schemas) -->
    <SchemaInjector
      pathname={Astro.url.pathname}
      pageTitle={title}
      article={articleSchema}
      review={reviewSchema}
      faq={faqSchema}
      customSchemas={customSchemas}
    />

    <!-- Legacy structured-data slot for backward compatibility -->
    <slot name="structured-data" />

    <!-- GDPR Cookie Consent Manager - MUST LOAD FIRST -->
    <script is:inline>
      // Inline critical consent logic to prevent any cookies before consent
      (function() {
        'use strict';
        window['ga-enabled'] = false;
        window['marketing-enabled'] = false;
        
        // Check for existing consent
        try {
          var stored = localStorage.getItem('cookie_consent');
          if (stored) {
            var consent = JSON.parse(stored);
            window['ga-enabled'] = consent.analytics || false;
            window['marketing-enabled'] = consent.marketing || false;
          }
        } catch (e) {}
      })();
    </script>
    
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7792548915836467" crossorigin="anonymous"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W42NG9QB"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot name="header" />
    
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <!-- GDPR Cookie Consent Banner (React Island) -->
    <CookieConsent 
      client:load 
      privacyPolicyUrl="/privacy" 
      cookiePolicyUrl="/cookies" 
    />

    <!-- Google Analytics (loads only with user consent) -->
    <Analytics />

    <!-- Pagefind search script (loaded async after consent) -->
    <script>
      window.addEventListener('load', () => {
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind.js';
        script.defer = true;
        document.head.appendChild(script);
      });
    </script>

    <!-- Universal Affiliate Click Tracker → GA4 affiliate_click + GTM affiliate_lead events -->
    <script is:inline>
      (function() {
        'use strict';

        var AFFILIATE_PARTNERS = {
          'see-guru':             { name: 'See Guru',             affId: 'SG-SUAG151' },
          'italki':               { name: 'iTalki',              affId: 'LEARNENGLISHLIFE' },
          'preply':               { name: 'Preply',              affId: 'LEARNENGLISHLIFE' },
          'cambly':               { name: 'Cambly',              affId: null },
          'busuu':                { name: 'Busuu',               affId: null },
          'babbel':               { name: 'Busuel',              affId: null },
          'duolingo':             { name: 'Duolingo',            affId: null },
          'rosetta-stone':        { name: 'Rosetta Stone',       affId: null },
          'elsa-speak':           { name: 'ELSA Speak',          affId: null },
          'rocket-languages':     { name: 'Rocket Languages',    affId: null },
          'pimsleur':             { name: 'Pimsleur',            affId: null },
          'verbling':             { name: 'Verbling',            affId: null },
          'italki-language-exchange': { name: 'iTalki',           affId: 'LEARNENGLISHLIFE' }
        };

        function getLinkType(link) {
          var parent = link.closest('section, article, div, aside') || link.parentElement;
          var id     = (parent && (parent.id || '')).toLowerCase();
          var cls    = (parent && (parent.className || '')).toLowerCase();

          if (id.includes('hero') || cls.includes('hero')) return 'hero';
          if (id.includes('sticky') || cls.includes('sticky') || cls.includes('fixed')) return 'sticky';
          if (id.includes('comparison') || cls.includes('comparison') ||
              cls.includes(' table')    || cls.includes('card')       ||
              cls.includes('winner')   || cls.includes('cta-box')    ||
              cls.includes('sidebar')  || cls.includes('widget'))    return 'comparison';
          if (link.parentElement && link.parentElement.tagName === 'P') return 'inline';
          return 'cta';
        }

        function getPartnerFromHref(href) {
          var m = href.match(/\/go\/([a-z0-9-]+)/i);
          if (m) return m[1].toLowerCase();
          if (href.includes('see.guru')) return 'see-guru';
          return null;
        }

        function trackAffiliateClick(link) {
          var href    = link.getAttribute('href') || '';
          var partner = getPartnerFromHref(href);
          if (!partner || !AFFILIATE_PARTNERS[partner]) return;

          var info      = AFFILIATE_PARTNERS[partner];
          var linkType  = getLinkType(link);
          var pagePath  = window.location.pathname;

          // 1. GA4 Event (direct gtag) - Only if analytics consent given
          if (typeof gtag === 'function' && window['ga-enabled']) {
            gtag('event', 'affiliate_click', {
              event_category:  'affiliate',
              event_label:      info.name,
              partner_name:     info.name,
              link_type:        linkType,
              currency:         'USD',
              value:            0,
              destination_url:  href,
              affiliate_id:     info.affId || '',
              page_path:        pagePath,
              transport_type:   'beacon'
            });
          }

          // 2. DataLayer Push for GTM (Triggers Meta Pixel 'Lead' and GAds Conversion)
          // Fires if marketing consent given OR if GTM handles its own consent
          if (window.dataLayer && window['marketing-enabled']) {
            window.dataLayer.push({
              event: 'affiliate_lead',
              event_category: 'Conversion',
              event_label: info.name,
              platform: info.name,
              destination_url: href,
              link_type: linkType,
              page_path: pagePath,
              affiliate_id: info.affId || ''
            });
          }

          console.log('[Affiliate Tracker] affiliate_click + affiliate_lead → partner=' + info.name);
        }

        function initTracker() {
          // Select all /go/ links AND direct see.guru links
          var links = document.querySelectorAll('a[href^="/go/"], a[href*="see.guru"]');
          links.forEach(function(link) {
            if (link.hasAttribute('data-aff-tracked')) return;
            link.setAttribute('data-aff-tracked', 'true');
            link.addEventListener('click', function() { trackAffiliateClick(link); }, { passive: true });
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initTracker);
        } else {
          initTracker();
        }
        
        // Re-init on consent update
        window.addEventListener('consentUpdated', initTracker);
      })();
    </script>
  </body>
</html>
