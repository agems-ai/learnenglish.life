---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalUrl,
  type = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteUrl = 'https://learnenglish.life';
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-adsense-account" content="ca-pub-7792548915836467" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, siteUrl).href} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Structured Data -->
    <slot name="structured-data" />

    <!-- GDPR Cookie Consent Manager - MUST LOAD FIRST -->
    <script is:inline>
      // Inline critical consent logic to prevent any cookies before consent
      (function() {
        'use strict';
        window['ga-enabled'] = false;
        window['marketing-enabled'] = false;
        
        // Check for existing consent
        try {
          var stored = localStorage.getItem('cookie_consent');
          if (stored) {
            var consent = JSON.parse(stored);
            window['ga-enabled'] = consent.analytics || false;
            window['marketing-enabled'] = consent.marketing || false;
          }
        } catch (e) {}
      })();
    </script>
    
    <!-- Google AdSense - Replace pub-XXXXXXXXXX with real publisher ID -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-XXXXXXXXXX" crossorigin="anonymous"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot name="header" />
    
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <!-- GDPR Cookie Consent Banner (React Island) -->
    <CookieConsent 
      client:load 
      privacyPolicyUrl="/privacy" 
      cookiePolicyUrl="/cookies" 
    />

    <!-- Google Analytics (loads only with user consent) -->
    <Analytics />

    <!-- Pagefind search script (loaded async after consent) -->
    <script>
      // Defer pagefind loading (functional cookie - optional)
      window.addEventListener('load', () => {
        // Only load pagefind if functional cookies are accepted
        // or if user hasn't made any choice (pagefind is lightweight)
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind.js';
        script.defer = true;
        document.head.appendChild(script);
      });
    </script>
  </body>
</html>
