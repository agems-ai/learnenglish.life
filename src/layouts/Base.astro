---
import '../styles/global.css';
import CookieConsent from '../components/CookieConsent';
import Analytics from '../components/Analytics.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalUrl?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalUrl,
  type = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const siteUrl = 'https://learnenglish.life';
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-adsense-account" content="ca-pub-7792548915836467" />

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-W42NG9QB');</script>
    <!-- End Google Tag Manager -->

    <!-- Google Analytics 4 (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q1D36CSBCC"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q1D36CSBCC');
    </script>

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, siteUrl).href} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={fullCanonical} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, siteUrl).href} />

    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Fonts preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Structured Data -->
    <slot name="structured-data" />

    <!-- GDPR Cookie Consent Manager - MUST LOAD FIRST -->
    <script is:inline>
      // Inline critical consent logic to prevent any cookies before consent
      (function() {
        'use strict';
        window['ga-enabled'] = false;
        window['marketing-enabled'] = false;
        
        // Check for existing consent
        try {
          var stored = localStorage.getItem('cookie_consent');
          if (stored) {
            var consent = JSON.parse(stored);
            window['ga-enabled'] = consent.analytics || false;
            window['marketing-enabled'] = consent.marketing || false;
          }
        } catch (e) {}
      })();
    </script>
    
    <!-- Google AdSense - Replace pub-XXXXXXXXXX with real publisher ID -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7792548915836467" crossorigin="anonymous"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W42NG9QB"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- Skip to main content -->
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <slot name="header" />
    
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <!-- GDPR Cookie Consent Banner (React Island) -->
    <CookieConsent 
      client:load 
      privacyPolicyUrl="/privacy" 
      cookiePolicyUrl="/cookies" 
    />

    <!-- Google Analytics (loads only with user consent) -->
    <Analytics />

    <!-- Pagefind search script (loaded async after consent) -->
    <script>
      // Defer pagefind loading (functional cookie - optional)
      window.addEventListener('load', () => {
        // Only load pagefind if functional cookies are accepted
        // or if user hasn't made any choice (pagefind is lightweight)
        const script = document.createElement('script');
        script.src = '/pagefind/pagefind.js';
        script.defer = true;
        document.head.appendChild(script);
      });
    </script>

    <!-- See Guru Affiliate Click Tracker -->
    <script>
      (function() {
        'use strict';
        
        // Wait for DOM and gtag to be ready
        function initTracker() {
          // Pattern 1: Direct See Guru affiliate links
          var affiliateLinks = document.querySelectorAll('a[href*="see.guru/?aff="], a[href*="see.guru%3Faff="]');
          
          // Pattern 2: Redirect page links
          var redirectLinks = document.querySelectorAll('a[href*="/go/see-guru"]');
          
          // Determine link type based on context
          function getLinkType(link) {
            var parent = link.closest('section, article, div');
            var id = parent ? (parent.id || '') : '';
            var classes = parent ? (parent.className || '') : '';
            
            // Hero sections
            if (id.includes('hero') || classes.includes('hero') || classes.includes('HeroCTA')) {
              return 'hero';
            }
            // Sticky CTAs
            if (id.includes('sticky') || classes.includes('sticky')) {
              return 'sticky';
            }
            // Comparison/table contexts
            if (id.includes('comparison') || classes.includes('comparison') || 
                classes.includes('table') || classes.includes('Table')) {
              return 'comparison';
            }
            // Inline text links
            if (link.parentElement && link.parentElement.tagName === 'P') {
              return 'inline';
            }
            // Default to CTA
            return 'cta';
          }
          
          // Track click and navigate
          function trackAndNavigate(link, e) {
            var linkType = getLinkType(link);
            var href = link.getAttribute('href');
            
            // Fire GA4 affiliate_click event
            if (typeof gtag !== 'undefined') {
              gtag('event', 'affiliate_click', {
                partner: 'See Guru',
                link_type: linkType,
                destination_url: href,
                affiliate_id: 'SG-SUAG151'
              });
            }
            
            // Also push to dataLayer for GTM
            if (typeof window.dataLayer !== 'undefined') {
              window.dataLayer.push({
                event: 'affiliate_click',
                affiliate_partner: 'See Guru',
                link_type: linkType,
                destination_url: href
              });
            }
          }
          
          // Attach to direct affiliate links
          affiliateLinks.forEach(function(link) {
            if (!link.hasAttribute('data-see-guru-tracked')) {
              link.setAttribute('data-see-guru-tracked', 'true');
              link.addEventListener('click', function(e) {
                trackAndNavigate(link, e);
              }, { passive: true });
            }
          });
          
          // Attach to redirect page links
          redirectLinks.forEach(function(link) {
            if (!link.hasAttribute('data-see-guru-tracked')) {
              link.setAttribute('data-see-guru-tracked', 'true');
              link.addEventListener('click', function(e) {
                trackAndNavigate(link, e);
              }, { passive: true });
            }
          });
        }
        
        // Run on DOM ready
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initTracker);
        } else {
          initTracker();
        }
      })();
    </script>

  </body>
</html>

    <!-- Affiliate Click Tracking for GA4 -->
    <script is:inline>
      function trackAffiliateClick(partner, linkType, destination) {
        if (typeof window.gtag !== 'function') return;
        
        var affiliateUrl = destination || 'https://see.guru/?aff=SG-SUAG151';
        var pageLocation = window.location.pathname || 'unknown';
        
        // Fire GA4 custom event
        window.gtag('event', 'affiliate_click', {
          partner: partner,
          link_type: linkType,
          destination_url: affiliateUrl,
          affiliate_id: 'SG-SUAG151',
          source_page: pageLocation,
          transport_type: 'beacon'
        });
        
        // Also push to dataLayer for GA4 standard tracking
        if (typeof window.dataLayer !== 'undefined') {
          window.dataLayer.push({
            event: 'affiliate_click',
            affiliate_partner: partner,
            affiliate_link_type: linkType,
            affiliate_destination: affiliateUrl,
            affiliate_source: pageLocation
          });
        }
        
        console.log('[Affiliate Tracking] ' + partner + ' - ' + linkType + ' - ' + pageLocation);
      }
      
      // Auto-attach tracking to See Guru CTA links
      document.addEventListener('DOMContentLoaded', function() {
        var seeGuruLinks = document.querySelectorAll('a[href*="see.guru"]');
        seeGuruLinks.forEach(function(link) {
          // Skip internal links and redirect pages
          if (link.href.includes('/go/') || link.href.includes('/reviews/see-guru') || link.href.includes('/compare/see-guru')) {
            return;
          }
          
          // Determine link type from surrounding context
          var linkType = 'cta_button';
          var parent = link.closest('section') || link.closest('div');
          if (parent) {
            var parentClass = parent.className || '';
            if (parentClass.includes('verdict')) linkType = 'verdict_cta';
            else if (parentClass.includes('sidebar')) linkType = 'sidebar_cta';
            else if (parentClass.includes('hero')) linkType = 'hero_cta';
            else if (parentClass.includes('top-pick')) linkType = 'top_pick_cta';
          }
          
          // Add onclick if not already present
          if (!link.hasAttribute('onclick')) {
            link.addEventListener('click', function() {
              trackAffiliateClick('See Guru', linkType, link.href);
            });
          }
        });
      });
    </script>
  </body>
</html>
